// ─────────────────────────────────────────────
// SPACE POINT — Gamification System
// ─────────────────────────────────────────────

/// Predefined level thresholds (seeded once, global for all orgs)
model SpacePointLevel {
  id             String   @id @default(cuid())
  order          Int      @unique
  name           String   // "Terra", "Lua", "Marte", "Saturno"…
  requiredPoints Int      @map("required_points")
  badgeNumber    Int      @map("badge_number")   // 1-24 → /public/space-point/badges/{n}.svg
  planetEmoji    String   @default("🪐")          @map("planet_emoji")

  seals          UserSpacePointSeal[]

  @@map("space_point_level")
}

/// Per-org Star consumption rules (debits per action)
model StarRule {
  id                String   @id @default(cuid())
  orgId             String   @map("org_id")
  action            String
  label             String
  stars             Int      @default(0)  // 0 = free
  cooldownHours     Int?     @map("cooldown_hours")
  isActive          Boolean  @default(true) @map("is_active")
  popupTemplateId   String?  @map("popup_template_id")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt      @map("updated_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, action])
  @@index([orgId])
  @@map("star_rule")
}

/// Per-org configurable rules: which actions earn how many points
model SpacePointRule {
  id                String   @id @default(cuid())
  orgId             String   @map("org_id")
  action            String   // "lead_won" | "create_event" | "create_agenda" | "create_workspace_card" …
  label             String   // human-readable, shown in settings
  points            Int      @default(0)
  cooldownHours     Int?     @map("cooldown_hours") // null = unlimited
  isActive          Boolean  @default(true) @map("is_active")
  popupTemplateId   String?  @map("popup_template_id") // optional linked popup template
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt      @map("updated_at")

  org          Organization          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  transactions SpacePointTransaction[]

  @@unique([orgId, action])
  @@index([orgId])
  @@map("space_point_rule")
}

/// Prizes/awards per ranking position per org
model SpacePointRankingPrize {
  id          String   @id @default(cuid())
  orgId       String   @map("org_id")
  rank        Int      // 1 = 1st place, 2 = 2nd, etc.
  period      String   @default("monthly") // "weekly" | "biweekly" | "monthly" | "annual" | "alltime"
  title       String
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt      @map("updated_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, rank, period])
  @@index([orgId])
  @@map("space_point_ranking_prize")
}

/// Accumulated points + level tracking per user-per-org
model UserSpacePoint {
  id           String    @id @default(cuid())
  userId       String    @map("user_id")
  orgId        String    @map("org_id")
  totalPoints  Int       @default(0)  @map("total_points")
  weeklyPoints Int       @default(0)  @map("weekly_points")
  weekStart    DateTime? @map("week_start")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt      @map("updated_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  transactions SpacePointTransaction[]
  seals        UserSpacePointSeal[]

  @@unique([userId, orgId])
  @@index([orgId, totalPoints])
  @@map("user_space_point")
}

/// Audit log of every point event
model SpacePointTransaction {
  id          String   @id @default(cuid())
  userPointId String   @map("user_point_id")
  ruleId      String?  @map("rule_id")
  points      Int
  description String
  metadata    Json?    @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")

  userPoint   UserSpacePoint  @relation(fields: [userPointId], references: [id], onDelete: Cascade)
  rule        SpacePointRule? @relation(fields: [ruleId], references: [id], onDelete: SetNull)

  @@index([userPointId])
  @@index([userPointId, createdAt])
  @@map("space_point_transaction")
}

/// Which level seals the user has unlocked
model UserSpacePointSeal {
  id          String   @id @default(cuid())
  userPointId String   @map("user_point_id")
  levelId     String   @map("level_id")
  earnedAt    DateTime @default(now()) @map("earned_at")

  userPoint   UserSpacePoint  @relation(fields: [userPointId], references: [id], onDelete: Cascade)
  level       SpacePointLevel @relation(fields: [levelId], references: [id], onDelete: Cascade)

  @@unique([userPointId, levelId])
  @@index([userPointId])
  @@map("user_space_point_seal")
}

/// Key→URL store for all configurable platform assets (badges, app icons, integration icons, branding)
model PlatformAsset {
  id        String   @id @default(cuid())
  key       String   @unique   // "badge:1", "app:tracking", "integration:whatsapp-business", "platform:logo"
  url       String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt       @map("updated_at")

  @@map("platform_asset")
}

/// Platform-level payment gateway configurations (Stripe, Asaas, etc.)
model PaymentGatewayConfig {
  id            String   @id @default(cuid())
  provider      String   // "stripe" | "asaas"
  label         String?
  secretKey     String
  publicKey     String?  // Stripe publishable key
  webhookSecret String?  // Stripe webhook signing secret
  environment   String   @default("production") // "sandbox" | "production"
  isActive      Boolean  @default(true)          @map("is_active")
  isDefault     Boolean  @default(false)         @map("is_default")
  createdAt     DateTime @default(now())          @map("created_at")
  updatedAt     DateTime @updatedAt               @map("updated_at")

  payments      StarsPayment[]

  @@map("payment_gateway_config")
}

/// Tracks individual Stars purchase payment attempts
model StarsPayment {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  organizationId String   @map("organization_id")
  packageId      String   @map("package_id")
  starsAmount    Int      @map("stars_amount")
  amountBrl      Decimal  @map("amount_brl")
  provider       String
  externalId     String?  @map("external_id")
  status         String   @default("pending") // pending | paid | failed | expired
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  gatewayConfig  PaymentGatewayConfig? @relation(fields: [gatewayId], references: [id])
  gatewayId      String?               @map("gateway_id")

  @@index([userId])
  @@index([organizationId])
  @@index([externalId])
  @@index([status])
  @@map("stars_payment")
}

// ─────────────────────────────────────────────
// NASA PAYMENT
// ─────────────────────────────────────────────

enum FinancialEntryStatus {
  PENDING    // Pendente
  PARTIAL    // Pago Parcial
  PAID       // Pago
  OVERDUE    // Vencido
  CANCELLED  // Cancelado
}

enum FinancialEntryType {
  RECEIVABLE  // Conta a Receber
  PAYABLE     // Conta a Pagar
}

enum PaymentAccountType {
  CHECKING  // Conta Corrente
  SAVINGS   // Poupança
  CASH      // Caixa físico
  DIGITAL   // Carteira digital
}

enum FinancialCategoryType {
  REVENUE   // Receita
  EXPENSE   // Despesa
  COST      // Custo
}

model PaymentBankAccount {
  id             String             @id @default(cuid())
  organizationId String             @map("organization_id")
  name           String
  bankName       String?            @map("bank_name")
  bankCode       String?            @map("bank_code")
  agency         String?
  account        String?
  type           PaymentAccountType @default(CHECKING)
  balance        Int                @default(0)     // em centavos
  isActive       Boolean            @default(true)  @map("is_active")
  isDefault      Boolean            @default(false) @map("is_default")
  color          String?            @default("#1E90FF")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt      @map("updated_at")

  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  entries        PaymentEntry[]

  @@index([organizationId])
  @@map("payment_bank_accounts")
}

model PaymentCategory {
  id             String                @id @default(cuid())
  organizationId String                @map("organization_id")
  name           String
  type           FinancialCategoryType
  color          String?               @default("#1E90FF")
  icon           String?
  parentId       String?               @map("parent_id")
  isActive       Boolean               @default(true) @map("is_active")
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt      @map("updated_at")

  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent         PaymentCategory?   @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children       PaymentCategory[]  @relation("CategoryHierarchy")
  entries        PaymentEntry[]

  @@index([organizationId])
  @@map("payment_categories")
}

model PaymentCostCenter {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  name           String
  description    String?
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt      @map("updated_at")

  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  entries        PaymentEntry[]

  @@index([organizationId])
  @@map("payment_cost_centers")
}

model PaymentContact {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  name           String
  document       String?  // CPF ou CNPJ
  email          String?
  phone          String?
  contactType    String   @default("BOTH") @map("contact_type") // CUSTOMER, SUPPLIER, BOTH
  notes          String?
  isActive       Boolean  @default(true) @map("is_active")
  creditLimit    Int      @default(0)    @map("credit_limit") // em centavos
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt      @map("updated_at")

  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  entries        PaymentEntry[]

  @@index([organizationId])
  @@map("payment_contacts")
}

model PaymentAccess {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  organizationId String   @map("organization_id")
  passwordHash   String   @map("password_hash")
  isAuthorized   Boolean  @default(false) @map("is_authorized")
  phone          String?  // para envio de PIN via WhatsApp
  authorizedById String?  @map("authorized_by_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt      @map("updated_at")

  user           User         @relation("PaymentAccessUser",        fields: [userId],         references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  authorizedBy   User?        @relation("PaymentAccessAuthorizer",  fields: [authorizedById], references: [id])

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@map("payment_access")
}

model PaymentEntry {
  id             String               @id @default(cuid())
  organizationId String               @map("organization_id")
  type           FinancialEntryType
  status         FinancialEntryStatus @default(PENDING)

  description    String
  amount         Int                  // em centavos
  paidAmount     Int                  @default(0) @map("paid_amount") // em centavos
  dueDate        DateTime             @map("due_date")
  paidAt         DateTime?            @map("paid_at")
  competenceDate DateTime?            @map("competence_date")

  documentNumber String?  @map("document_number")
  notes          String?
  attachmentUrl  String?  @map("attachment_url")

  categoryId    String?  @map("category_id")
  costCenterId  String?  @map("cost_center_id")
  contactId     String?  @map("contact_id")
  accountId     String?  @map("account_id")

  // Parcelamento
  installmentTotal   Int?    @map("installment_total")
  installmentCurrent Int?    @map("installment_current")
  installmentGroupId String? @map("installment_group_id")

  // Recorrência
  isRecurring    Boolean @default(false) @map("is_recurring")
  recurrenceType String? @map("recurrence_type") // daily, weekly, monthly, yearly

  createdById   String?  @map("created_by_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt      @map("updated_at")

  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category       PaymentCategory?    @relation(fields: [categoryId], references: [id])
  costCenter     PaymentCostCenter?  @relation(fields: [costCenterId], references: [id])
  contact        PaymentContact?     @relation(fields: [contactId], references: [id])
  account        PaymentBankAccount? @relation(fields: [accountId], references: [id])
  createdBy      User?               @relation("PaymentEntryCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([type])
  @@index([status])
  @@index([dueDate])
  @@index([contactId])
  @@index([categoryId])
  @@index([installmentGroupId])
  @@map("payment_entries")
}

/// Customizable popup templates for achievements and stars rewards
model AchievementPopupTemplate {
  id                String   @id @default(cuid())
  name              String   // e.g., "Parabéns Lua", "Conquista Especial"
  type              String   // "achievement" | "stars_reward" | "level_up"
  title             String   // e.g., "Parabéns você chegou na Lua"
  message           String   // e.g., "Você completou um grande feito"
  primaryColor      String   @default("#7a1fe7")   // Hex color for primary elements
  accentColor       String   @default("#a855f7")   // Hex color for accents
  backgroundColor   String   @default("#1a0a3d")   // Card background
  textColor         String   @default("#ffffff")   // Main text color
  iconUrl           String?  // Optional custom icon/badge URL
  enableConfetti    Boolean  @default(true)        // Enable confetti animation
  enableSound       Boolean  @default(true)        // Enable success sound
  dismissDuration   Int      @default(5000)        // Auto-dismiss in milliseconds
  customJson        Json     @default("{}")        // Store additional customization
  isActive          Boolean  @default(true)        @map("is_active")
  createdAt         DateTime @default(now())       @map("created_at")
  updatedAt         DateTime @updatedAt            @map("updated_at")

  @@index([type])
  @@map("achievement_popup_template")
}

