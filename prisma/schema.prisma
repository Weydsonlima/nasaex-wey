// ─── NASA Planner ──────────────────────────────────────────────────────────────

enum NasaPlannerPostStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  SCHEDULED
  PUBLISHED
  FAILED
}

enum NasaPlannerPostType {
  STATIC
  CAROUSEL
  REEL
  STORY
}

enum NasaPlannerCardStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model NasaPlanner {
  id             String  @id @default(cuid())
  organizationId String  @map("organization_id")
  name           String
  description    String?

  brandName   String? @map("brand_name")
  brandSlogan String? @map("brand_slogan")
  website     String?

  icp         String? @map("icp")
  swot        Json    @default("{}")
  positioning String?

  toneOfVoice    String?  @map("tone_of_voice")
  keyMessages    String[] @map("key_messages")
  forbiddenWords String[] @map("forbidden_words")

  primaryColors   String[] @map("primary_colors")
  secondaryColors String[] @map("secondary_colors")
  fonts           Json     @default("{}")

  logoLight      String? @map("logo_light")
  logoDark       String? @map("logo_dark")
  logoSquare     String? @map("logo_square")
  logoHorizontal String? @map("logo_horizontal")

  defaultHashtags String[] @map("default_hashtags")
  defaultCtas     String[] @map("default_ctas")
  examplePosts    String[] @map("example_posts")
  showBranding    Boolean  @default(true) @map("show_branding")

  anthropicApiKey String? @map("anthropic_api_key")
  clientOrgId     String? @map("client_org_id")
  clientOrgName   String? @map("client_org_name")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  orgProjectId String? @map("org_project_id")

  organization              Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  orgProject                OrgProject?                @relation(fields: [orgProjectId], references: [id], onDelete: SetNull)
  posts                     NasaPlannerPost[]
  mindMaps                  NasaPlannerMindMap[]
  calendarShares            NasaPlannerCalendarShare[]
  campaignPlanners          NasaCampaignPlanner[]
  clientOnboardingProcesses ClientOnboardingProcess[]

  @@index([organizationId])
  @@map("nasa_planner")
}

model NasaPlannerPost {
  id             String @id @default(cuid())
  plannerId      String @map("planner_id")
  organizationId String @map("organization_id")
  createdById    String @map("created_by_id")

  type   NasaPlannerPostType   @default(STATIC)
  status NasaPlannerPostStatus @default(DRAFT)

  title    String?
  caption  String?
  hashtags String[]
  cta      String?

  aiPrompt   String? @map("ai_prompt")
  starsSpent Int     @default(0) @map("stars_spent")

  scheduledAt DateTime? @map("scheduled_at")
  publishedAt DateTime? @map("published_at")

  targetNetworks String[] @map("target_networks")
  thumbnail      String?

  orgProjectId   String?  @map("org_project_id")
  clientOrgName  String?  @map("client_org_name")
  campaignId     String?  @map("campaign_id")
  referenceLinks String[] @default([]) @map("reference_links")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  planner    NasaPlanner            @relation(fields: [plannerId], references: [id], onDelete: Cascade)
  createdBy  User                   @relation("NasaPlannerPostCreatedBy", fields: [createdById], references: [id])
  orgProject OrgProject?            @relation(fields: [orgProjectId], references: [id], onDelete: SetNull)
  campaign   NasaCampaignPlanner?   @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  slides     NasaPlannerPostSlide[]

  @@index([plannerId, status])
  @@index([plannerId, scheduledAt])
  @@index([organizationId])
  @@map("nasa_planner_posts")
}

model NasaPlannerPostSlide {
  id     String @id @default(cuid())
  postId String @map("post_id")
  order  Int    @default(0)

  imageKey      String? @map("image_key")
  headline      String?
  subtext       String?
  overlayConfig Json    @default("{}") @map("overlay_config")

  createdAt DateTime @default(now()) @map("created_at")

  post NasaPlannerPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, order])
  @@map("nasa_planner_post_slides")
}

model NasaPlannerMindMap {
  id        String  @id @default(cuid())
  plannerId String  @map("planner_id")
  name      String
  template  String? // "mindmap", "gantt", "diagram", "checklist"
  nodes     Json    @default("[]")
  edges     Json    @default("[]")
  viewport  Json    @default("{}")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  planner NasaPlanner       @relation(fields: [plannerId], references: [id], onDelete: Cascade)
  cards   NasaPlannerCard[]

  @@index([plannerId])
  @@map("nasa_planner_mind_maps")
}

model NasaPlannerCard {
  id        String @id @default(cuid())
  mindMapId String @map("mind_map_id")
  plannerId String @map("planner_id")

  title       String
  description String?
  status      NasaPlannerCardStatus @default(PENDING)
  priority    String                @default("MEDIUM")

  assigneeIds String[]  @map("assignee_ids")
  dueDate     DateTime? @map("due_date")

  linkedApp String? @map("linked_app")
