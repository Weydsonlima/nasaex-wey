  domainSource              NasaPageDomainSource? @map("domain_source")
  domainVerifyToken         String?               @map("domain_verify_token")
  isTemplate                Boolean               @default(false) @map("is_template")
  templateMarkedByModerator Boolean               @default(false) @map("template_marked_by_moderator")
  templateCategory          String?               @map("template_category")
  starsSpent                Int                   @default(0) @map("stars_spent")
  createdAt                 DateTime              @default(now()) @map("created_at")
  updatedAt                 DateTime              @updatedAt @map("updated_at")

  organization   Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  versions       NasaPageVersion[]
  visits         NasaPageVisit[]
  assets         NasaPageAsset[]
  domainPurchase NasaPageDomainPurchase?

  orgAsSpacehome Organization? @relation("OrgSpacehome")

  @@index([organizationId])
  @@index([status])
  @@index([customDomain])
  @@map("nasa_pages")
}

