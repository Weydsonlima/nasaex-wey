}

model WorkspaceFolderItem {
  folderId    String @map("folder_id")
  workspaceId String @map("workspace_id")
  order       Int    @default(0)

  folder    WorkspaceFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)
