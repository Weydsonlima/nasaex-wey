  @@map("user_space_help_badge")
}

model NasaRouteCategory {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  iconKey     String?  @map("icon_key")
  order       Int      @default(0)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  courses NasaRouteCourse[]

  @@map("nasa_route_category")
}

model NasaRouteCourse {
  id                 String    @id @default(cuid())
  slug               String
  title              String
  subtitle           String?
  description        String?
  coverUrl           String?   @map("cover_url")
  trailerUrl         String?   @map("trailer_url")
  level              String    @default("beginner")
  durationMin        Int?      @map("duration_min")
  format             String    @default("course") // "course" | "training" | "mentoring"
  creatorOrgId       String    @map("creator_org_id")
  creatorUserId      String    @map("creator_user_id")
  categoryId         String?   @map("category_id")
  priceStars         Int       @default(0) @map("price_stars")
  isPublished        Boolean   @default(false) @map("is_published")
  publishedAt        DateTime? @map("published_at")
  studentsCount      Int       @default(0) @map("students_count")
  rewardSpOnComplete Int       @default(0) @map("reward_sp_on_complete")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  creatorOrg   Organization           @relation("NasaRouteCreatorOrg", fields: [creatorOrgId], references: [id], onDelete: Cascade)
  creatorUser  User                   @relation("NasaRouteCreatorUser", fields: [creatorUserId], references: [id], onDelete: Restrict)
  category     NasaRouteCategory?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  modules      NasaRouteModule[]
  lessons      NasaRouteLesson[]
  enrollments  NasaRouteEnrollment[]
  progress     NasaRouteProgress[]
  freeAccess   NasaRouteFreeAccess[]
  plans        NasaRoutePlan[]
  certificates NasaRouteCertificate[]

  @@unique([creatorOrgId, slug])
  @@index([creatorOrgId])
  @@index([categoryId])
  @@index([isPublished, publishedAt])
  @@map("nasa_route_course")
}

model NasaRouteModule {
  id        String   @id @default(cuid())
  courseId  String   @map("course_id")
  order     Int      @default(0)
  title     String
  summary   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  course  NasaRouteCourse   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons NasaRouteLesson[]

  @@index([courseId, order])
  @@map("nasa_route_module")
}

model NasaRouteLesson {
  id            String   @id @default(cuid())
  courseId      String   @map("course_id")
  moduleId      String?  @map("module_id")
  order         Int      @default(0)
  title         String
  summary       String?
  contentMd     String?  @map("content_md")
  videoUrl      String?  @map("video_url")
  videoProvider String?  @map("video_provider") // "youtube" | "vimeo"
  videoId       String?  @map("video_id")
  durationMin   Int?     @map("duration_min")
  isFreePreview Boolean  @default(false) @map("is_free_preview")
  awardSp       Int      @default(10) @map("award_sp")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  course      NasaRouteCourse       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  module      NasaRouteModule?      @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  planLessons NasaRoutePlanLesson[]

  @@index([courseId, order])
  @@map("nasa_route_lesson")
