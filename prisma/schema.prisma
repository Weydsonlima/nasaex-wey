  REJECTED
}

model SpaceStation {
  id            String            @id @default(cuid())
  type          StationType
  userId        String?           @unique @map("user_id")
  orgId         String?           @unique @map("org_id")
  nick          String            @unique
  isPublic      Boolean           @default(false) @map("is_public")
