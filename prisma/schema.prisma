  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  course      NasaRouteCourse       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  plan        NasaRoutePlan?        @relation(fields: [planId], references: [id], onDelete: SetNull)
  buyerOrg    Organization?         @relation("NasaRouteBuyerOrg", fields: [buyerOrgId], references: [id], onDelete: SetNull)
  certificate NasaRouteCertificate?

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@index([planId])
  @@map("nasa_route_enrollment")
}

model NasaRouteProgress {
  id                 String    @id @default(cuid())
  userId             String    @map("user_id")
  courseId           String    @map("course_id")
  completedLessonIds String[]  @map("completed_lesson_ids")
  lastLessonId       String?   @map("last_lesson_id")
  startedAt          DateTime  @default(now()) @map("started_at")
  completedAt        DateTime? @map("completed_at")

  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  course NasaRouteCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@map("nasa_route_progress")
}

model NasaRouteFreeAccess {
  id           String   @id @default(cuid())
  creatorOrgId String   @map("creator_org_id")
  userId       String   @map("user_id")
  courseId     String?  @map("course_id") // null = todos os cursos da org
  grantedById  String   @map("granted_by_id")
  grantedAt    DateTime @default(now()) @map("granted_at")
