  readAt         DateTime? @map("read_at")
  sentWhatsApp   Boolean   @default(false) @map("sent_whatsapp")
  createdAt      DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([organizationId])
  @@map("user_notification")
}

model UserNotificationPreference {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  organizationId String   @map("organization_id")
  notifType      String   @map("notif_type")
  inApp          Boolean  @default(true) @map("in_app")
  whatsApp       Boolean  @default(false) @map("whats_app")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId, notifType])
  @@index([userId])
