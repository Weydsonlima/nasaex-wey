# ─────────────────────────────────────────────
# BANCO DE DADOS
# ─────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/nasaex"

# ─────────────────────────────────────────────
# AUTENTICAÇÃO (Better Auth)
# ─────────────────────────────────────────────
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google OAuth (opcional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email para envio de convites e verificações
RESEND_API_KEY=
BETTER_AUTH_EMAIL=noreply@seudominio.com

# ─────────────────────────────────────────────
# INTELIGÊNCIA ARTIFICIAL
# ─────────────────────────────────────────────
# Google Gemini — usado no chat de agendamento e composição de mensagens
GOOGLE_GENERATIVE_AI_API_KEY=

# OpenAI — usado no chat interno (/api/chat)
OPENAI_API_KEY=

# ─────────────────────────────────────────────
# WHATSAPP (UAZAPI)
# ─────────────────────────────────────────────
# ATENÇÃO: o código usa NEXT_PUBLIC_UAZAPI_BASE_URL (não UAZAPI_BASE_URL)
NEXT_PUBLIC_UAZAPI_BASE_URL=https://api.uazapi.com
UAZAPI_TOKEN=

# ─────────────────────────────────────────────
# REAL-TIME (Pusher)
# ─────────────────────────────────────────────
PUSHER_APP_ID=
PUSHER_SECRET=
NEXT_PUBLIC_PUSHER_APP_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=sa1

# ─────────────────────────────────────────────
# ARMAZENAMENTO DE ARQUIVOS (AWS S3 / R2 / MinIO)
# ─────────────────────────────────────────────
AWS_ENDPOINT_URL_S3=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
NEXT_PUBLIC_S3_BUCKET_NAME_IMAGES=
NEXT_PUBLIC_S3_BUCKET_CONSTRUCTOR_URL=

# ─────────────────────────────────────────────
# AUTOMAÇÕES (Inngest)
# ─────────────────────────────────────────────
# Não são necessárias em desenvolvimento local (Inngest Dev Server não exige)
# Em produção (Vercel, etc.), configure no dashboard do Inngest
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ─────────────────────────────────────────────
# INTEGRAÇÕES EXTERNAS (opcional)
# ─────────────────────────────────────────────
WEBHOOK_AI_AGENT_N8N=
