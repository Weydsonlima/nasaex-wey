
generator client {
  provider      = "prisma-client"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now()) @updatedAt
  sessions      Session[]
  accounts      Account[]

  members                 Member[]
  invitations             Invitation[]
  trackings               TrackingParticipant[]
  leadHistories           LeadHistory[]
  participantOnActions    ActionsUserParticipant[]
  responsibleOnActions    ActionsUserResponsible[]
  actions                 Action[]
  responsibleOnSubActions SubActionUserResponsible[]
  responsibleOnLeads      Lead[]  @relation("LeadResponsible")
  worflows Workflow[]
  forms    Form[]
  leadFiles LeadFile[]
  insightShares InsightShares[]
  agendaResponsibles AgendaResponsible[]
  appointments Appointment[]
  trackingConsultants TrackingConsultant[]
  forgeProductsCreated  ForgeProduct[]          @relation("ForgeProductCreatedBy")
  forgeProposalsResp    ForgeProposal[]         @relation("ForgeProposalResponsible")
  forgeProposalsCreated ForgeProposal[]         @relation("ForgeProposalCreatedBy")
  forgeContractsCreated ForgeContract[]         @relation("ForgeContractCreatedBy")
  forgeTemplatesCreated ForgeContractTemplate[] @relation("ForgeTemplateCreatedBy")
  nboxFoldersCreated NBoxFolder[] @relation("NBoxFolderCreatedBy")
  nboxItemsCreated   NBoxItem[]   @relation("NBoxItemCreatedBy")
  nasaPostsCreated   NasaPost[]   @relation("NasaPostCreatedBy")

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  activeOrganizationId String?

  @@unique([token])
  @@map("session")
  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@map("verification")
  @@index([identifier])
}

model Organization {
  id          String       @id @default(cuid())
  name        String
  slug        String
  logo        String?
  createdAt   DateTime
  metadata    String?

  // ── STARS ──────────────────────────────────
  planId           String?   @map("plan_id")
  starsBalance     Int       @default(0)       @map("stars_balance")
  starsCycleStart  DateTime? @map("stars_cycle_start")
  starsAlertConfig Json      @default("{}") @map("stars_alert_config")

  members     Member[]
  invitations Invitation[]
  trackings   Tracking[]
  tags        Tag[]
  whatsappInstances    WhatsAppInstance[]
  actions              Action[]
  insightShares        InsightShares[]
  agendas              Agenda[]
  widgets              Widget[]
  platformIntegrations PlatformIntegration[]
  forgeProducts        ForgeProduct[]
  forgeProposals       ForgeProposal[]
  forgeContracts       ForgeContract[]
  forgeTemplates       ForgeContractTemplate[]
  forgeSettings        ForgeSettings?
  plan                 Plan?                  @relation(fields: [planId], references: [id], onDelete: SetNull)
  starTransactions     StarTransaction[]
  workspaceIntegrations WorkspaceIntegration[]
  nboxFolders      NBoxFolder[]
  nboxItems        NBoxItem[]
  nasaPostBrandConfig NasaPostBrandConfig?
  nasaPosts           NasaPost[]
  orgPermissions   OrgPermission[]
  activityLogs     OrgActivityLog[]
  systemActivityLogs SystemActivityLog[]
  userPresences      UserPresence[]

  @@unique([slug])
  @@map("organization")
}

model Member {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String
  createdAt      DateTime

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
  @@map("member")
}

model Invitation {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           String?
  status         String
  expiresAt      DateTime
  inviterId      String
  user           User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("invitation")
  @@index([organizationId])
  @@index([email])
}

// ─────────────────────────────────────────────
// TRACKING
// ─────────────────────────────────────────────

model Tracking {
  id             String   @id @default(cuid())
  name           String
  description    String?
  organizationId String   @map("organization_id")
  isArchived     Boolean  @default(false) @map("is_archived")
  globalAiActive Boolean  @default(false) @map("global_ai_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relacionamentos
  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  participants   TrackingParticipant[]
  status         Status[]
  leads          Lead[]
  tags           Tag[]
  winLossReasons WinLossReason[]
  actions        Action[]
  workflows      Workflow[]
  forms          Form[]
  whatsappInstance WhatsAppInstance?
  conversations  Conversation[]
  agendas        Agenda[]
  appointments   Appointment[]
  aiSettings     AiSettings?
  trackingConsultants TrackingConsultant[]

  @@map("tracking")
}

model AiSettings {
  id String @id @default(cuid())
  prompt String
  assistantName String? @map("assistant_name")
  finishSentence String? @map("finish_sentence")
  isAudioEnabled Boolean @default(false) @map("is_audio_enabled")

  trackingId String @unique
  tracking Tracking @relation(fields: [trackingId], references: [id])

  @@map("ai_setting")
}

enum ReasonType {
  WIN // Ganho
  LOSS // Perda
}

enum TagType {
  CUSTOM
  SYSTEM
}

model WinLossReason {
  id         String     @id @default(cuid())
  name       String
  type       ReasonType // GANHO ou PERDA
  trackingId String     @map("tracking_id")
  isActive   Boolean    @default(true) @map("is_active")
  order      Int        @default(0)
  createdAt  DateTime   @default(now()) @map("created_at")

  tracking      Tracking      @relation(fields: [trackingId], references: [id], onDelete: Cascade)
  leadHistories LeadHistory[]

  @@index([trackingId])
  @@map("win_loss_reasons")
}

model TrackingConsultant {
  id         String   @id @default(cuid())
  trackingId String   @map("tracking_id")
  userId     String   @map("user_id")
  maxFlow    Int      @default(0)   @map("max_flow")
  isActive   Boolean  @default(true)

  tracking Tracking @relation( fields: [trackingId], references: [id], onDelete: Cascade)  
  user     User     @relation( fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, trackingId])
  @@map("tracking_consultant")
}

model TrackingParticipant {
  id         String          @id @default(cuid())
  userId     String          @map("user_id")
  trackingId String          @map("tracking_id")
  role       ParticipantRole @default(MEMBER)
  createdAt  DateTime        @default(now()) @map("created_at")
  tracking   Tracking        @relation(fields: [trackingId], references: [id], onDelete: Cascade)
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, trackingId])
  @@map("tracking_participant")
}

enum ParticipantRole {
  OWNER // Criador, controle total
  ADMIN // Pode gerenciar participantes
  MEMBER // Pode visualizar e interagir
  VIEWER // Apenas visualização
}

model Status {
  id         String   @id @default(cuid())
  name       String
  color      String?  @default("#1447e6")
  order      Decimal  @db.Decimal(20, 10) @default(0)
  trackingId String   @map("tracking_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Relacionamentos
  tracking Tracking @relation(fields: [trackingId], references: [id], onDelete: Cascade)
  leads    Lead[]

  @@index([trackingId, order])
  @@map("status")
}

enum LeadAction {
  ACTIVE // Lead ativo no funil
  DELETED // Excluído (lixeira)
  WON // Ganho
  LOST // Perdido
}

model LeadHistory {
  id        String     @id @default(cuid())
  leadId    String     @map("lead_id")
  action    LeadAction
  reasonId  String?    @map("reason_id")
  notes     String?
  userId    String     @map("user_id")
  createdAt DateTime   @default(now()) @map("created_at")

  // Relacionamentos
  lead   Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  reason WinLossReason? @relation(fields: [reasonId], references: [id], onDelete: SetNull)
  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([action])
  @@index([createdAt])
  @@map("lead_history")
}

enum LeadSource {
  DEFAULT
  WHATSAPP
  FORM
  AGENDA
  INSTAGRAM
  TIKTOK
  LINKEDIN
  GMAIL
  GOOGLE_MAPS
  OTHER
}

enum Temperature {
  COLD
  WARM
  HOT
  VERY_HOT
}

enum StatusFlow {
  ACTIVE
  WAITING
  FINISHED
} 

model Lead {
  id          String  @id @default(cuid())
  name        String
  email       String?
  phone       String?
  document    String?
  profile     String?
  description String?
  statusId    String  @map("status_id")
  trackingId  String  @map("tracking_id")
  responsibleId String? @map("responsible_id")
  order      Decimal @db.Decimal(20, 10) @default(0)
  source      LeadSource @default(DEFAULT)
  temperature Temperature @default(COLD)
  amount Decimal @db.Decimal(15, 2) @default(0)
  statusFlow StatusFlow @default(ACTIVE) @map("status_flow")

  currentAction LeadAction @default(ACTIVE) @map("current_action")
  isActive      Boolean    @default(true) @map("is_active")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  closedAt  DateTime? @map("closed_at")

  // Relacionamentos
  status   Status   @relation(fields: [statusId], references: [id], onDelete: Cascade)
  tracking Tracking @relation(fields: [trackingId], references: [id], onDelete: Cascade)
  responsible User? @relation("LeadResponsible", fields: [responsibleId], references: [id], onDelete: SetNull)

  conversation Conversation? 

  leadTags LeadTag[]
  history  LeadHistory[]
  files    LeadFile[]
  actions  Action[]
  appointments Appointment[]
  forgeProposals ForgeProposal[]

  @@index([trackingId])
  @@index([statusId, order])
  @@index([email])
  @@index([phone])
  @@index([createdAt])
  @@index([currentAction])
  @@index([isActive])
  @@index([responsibleId])
  @@unique([phone, trackingId])
  @@map("leads")
}

model Tag {
  id             String   @id @default(cuid())
  name           String
  slug           String
  color          String?  @default("#1447e6")
  description    String?
  icon           String?
  type           TagType  @default(CUSTOM)
  organizationId String   @map("organization_id")
  trackingId     String?  @map("tracking_id") 
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  whatsappId String? @map("whatsapp_id")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tracking     Tracking?    @relation(fields: [trackingId], references: [id], onDelete: Cascade)
  leadTags     LeadTag[]

  // 👈 Importante: nome único por contexto
  @@unique([slug, organizationId, trackingId])
  @@unique([name, organizationId, trackingId])
  @@index([organizationId])
  @@index([trackingId])
  @@map("tags")
}

model LeadTag {
  id        String   @id @default(cuid())
  leadId    String   @map("lead_id")
  tagId     String   @map("tag_id")
  createdAt DateTime @default(now()) @map("created_at")

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([leadId, tagId])
  @@index([leadId])
  @@index([tagId])
  @@map("lead_tags")
}

model LeadFile {
  id        String   @id @default(cuid())
  leadId    String   @map("lead_id")
  fileUrl   String   @map("file_url")
  mimeType  String   @map("mime_type")
  createdAt DateTime @default(now()) @map("created_at")
  name String

  createdBy String? @map("created_by")
  creator User? @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([createdBy])
  @@map("lead_files")
}

// ─────────────────────────────────────────────
// AÇÕES
// ─────────────────────────────────────────────


model ActionsUserParticipant {
  id        String   @id @default(cuid())
  actionId  String   @map("action_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  action Action @relation(fields: [actionId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([actionId, userId])
  @@index([userId])
}

model ActionsUserResponsible {
  id       String @id @default(cuid())
  actionId String @map("action_id")
  userId   String @map("user_id")

  action Action @relation(fields: [actionId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([actionId, userId])
  @@map("actions_user_responsibles")
}

enum TypeAction {
  TASK
  ACTION
  MEETING
  NOTE
}

model Action {
  id             String     @id @default(cuid())
  title          String
  description    String?
  score          Int        @default(0)
  isDone         Boolean    @default(false) @map("is_done")
  type           TypeAction @default(TASK)
  trackingId     String?    @map("tracking_id")
  organizationId String?    @map("organization_id")
  createdBy      String     @map("created_by")
  leadId         String?    @map("lead_id")
  startDate      DateTime?  @map("start_date")
  endDate        DateTime?  @map("end_date")
  closedAt       DateTime?  @map("closed_at")
  createdAt      DateTime   @default(now()) @map("created_at")

  user         User          @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  lead         Lead?         @relation(fields: [leadId], references: [id], onDelete: SetNull)
  tracking     Tracking?     @relation(fields: [trackingId], references: [id], onDelete: SetNull)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  participants ActionsUserParticipant[]
  responsibles ActionsUserResponsible[]
  subActions   SubActions[]

  @@index([leadId])
  @@index([createdBy])
  @@index([isDone])
  @@index([type])
  @@index([startDate])
  @@index([endDate])
  @@index([closedAt])
  @@map("actions")
}

model SubActionUserResponsible {
  id          String @id @default(cuid())
  userId      String @map("user_id")
  subActionId String @map("sub_action_id")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  subAction SubActions @relation(fields: [subActionId], references: [id], onDelete: Cascade)

  @@unique([userId, subActionId])
  @@map("sub_actions_user_responsible")
}

model SubActions {
  id           String                     @id @default(cuid())
  title        String
  description  String?
  isDone       Boolean                    @default(false) @map("is_done")
  finishDate   DateTime?                  @map("finish_date")
  createdAt    DateTime                   @default(now()) @map("created_at")
  actionId     String                     @map("action_id")
  action       Action                     @relation(fields: [actionId], references: [id])
  responsibles SubActionUserResponsible[]

  @@index([actionId])
  @@index([isDone])
  @@index([finishDate])
  @@map("sub_action")
}

// ─────────────────────────────────────────────
// AUTOMAÇÕES
// ─────────────────────────────────────────────

model Workflow {
  id         String   @id @default(cuid())
  name       String
  description String?
  userId     String?  @map("user_id")
  trackingId String   @map("tracking_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt  @map("updated_at")

  user     User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  tracking Tracking @relation(fields: [trackingId], references: [id], onDelete: Cascade)

  nodes Node[]
  connections Connection[]

  @@map("workflows")
}

enum NodeType {
  // Gatilhos
  INITIAL
  MANUAL_TRIGGER
  NEW_LEAD
  MOVE_LEAD_STATUS
  LEAD_TAGGED
  AI_FINISHED
  // LEAD_UNTAGGED

  // Execuções
  HTTP_REQUEST
  MOVE_LEAD
  SEND_MESSAGE
  WAIT
  WIN_LOSS
  TAG
  TEMPERATURE
  RESPONSIBLE
}

model Node {
  id String @id @default(cuid())
  workflowId String @map("workflow_id")
  name String
  type NodeType
  position Json
  data Json @default("{}")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt  @map("updated_at")

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  outputConnections Connection[] @relation("FromNode")
  inputConnections Connection[] @relation("ToNode")

  @@map("nodes")
}

model Connection {
  id String @id @default(cuid())
  workflowId String @map("workflow_id")
  fromNodeId String @map("from_node_id")
  toNodeId String @map("to_node_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt  @map("updated_at")
  fromOutput String @default("main")
  toInput String @default("main")

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  fromNode Node @relation("FromNode", fields: [fromNodeId], references: [id], onDelete: Cascade)
  toNode Node @relation("ToNode", fields: [toNodeId], references: [id], onDelete: Cascade)

  @@unique([fromNodeId, toNodeId, fromOutput, toInput])
  @@map("connections")
}

// ─────────────────────────────────────────────
// FORMULÁRIO
// ─────────────────────────────────────────────

model Form {
  id String @id @default(cuid())
  userId String @map("user_id")
  trackingId String @map("tracking_id")
  name String
  description String?
  published Boolean @default(false)
  content String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt  @map("updated_at")

  visits Int @default(0)
  submissions Int @default(0)

  createdBy     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tracking Tracking @relation(fields: [trackingId], references: [id], onDelete: Cascade)

  formSubmissions FormSubmission[]

  shareUrl String @unique @map("share_url")

  @@map("forms")
}

model FormSubmission {
  id String @id @default(cuid())
  formId String @map("form_id")
  createdAt DateTime @default(now()) @map("created_at")
  form Form @relation(fields: [formId], references: [id], onDelete: Cascade)
  
  content String

  @@map("form_submissions")
}

// ─────────────────────────────────────────────
// CHAT
// ─────────────────────────────────────────────

model Conversation {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now()) @map("created_at")
  lastMessageAt DateTime @updatedAt @map("last_message_at")
  name          String?
  isGroup       Boolean  @default(false)
  
  remoteJid     String   @map("remote_jid")
  profilePicUrl String?  @map("profile_pic_url")
  isActive      Boolean  @default(true) @map("is_active")
  
  lead   Lead   @relation(fields: [leadId], references: [id] , onDelete: Cascade)
  leadId String @unique @map("lead_id")
  trackingId    String   @map("tracking_id")
  tracking      Tracking @relation(fields: [trackingId], references: [id], onDelete: Cascade)

  lastMessageId String? @unique @map("last_message_id")
  lastMessage Message? @relation(fields: [lastMessageId], references: [id])

  messages      Message[]        @relation("Messages")

  @@unique([leadId, trackingId])
  @@unique([remoteJid, trackingId])
  
  @@index([isActive])
  @@index([lastMessageAt])
  @@index([trackingId])
  @@map("conversations")
}

enum MessageStatus {
  SENT
  SEEN
  DELETED
}

model Message {
  id        String    @id @default(cuid())
  body      String?
  createdAt DateTime  @default(now()) @map("created_at")
  
  messageId        String   @unique @map("message_id")
  fromMe           Boolean  @default(false) @map("from_me")
  status           MessageStatus   @default(SENT)
  seen             Boolean  @default(false)
  
  mediaUrl         String?  @map("media_url")
  mediaType        String?  @map("media_type")
  mediaCaption     String?  @map("media_caption")
  mimetype         String?
  fileName         String?  @map("file_name")
  
  quotedMessageId  String?  @map("quoted_message_id")
  quotedMessage    Message? @relation("QuotedMessages", fields: [quotedMessageId], references: [id], onDelete: SetNull)
  quotes           Message[] @relation("QuotedMessages")
  conversationId String 
  senderId       String?
  senderName     String?

  conversation   Conversation @relation("Messages", fields: [conversationId], references: [id], onDelete: Cascade)
  LastMessage Conversation?
  
  @@index([conversationId, createdAt])
  @@index([status])
  @@index([fromMe])
  @@map("messages")
}

enum WhatsAppInstanceStatus {
  CONNECTED
  DISCONNECTED
}

model WhatsAppInstance {
  id              String   @id @default(cuid())
  instanceName    String   @map("instance_name")
  instanceId      String   @unique @map("instance_id")
  apiKey          String @unique  @map("api_key") // Token
  baseUrl         String   @map("base_url") // URL
  status          WhatsAppInstanceStatus @default(DISCONNECTED)
  qrCode          String?  @map("qr_code") // Base64 do QR Code
  phoneNumber     String?  @map("phone_number") // Número conectado
  profileName     String?  @map("profile_name")
  profilePicUrl   String?  @map("profile_pic_url")
  organizationId  String   @map("organization_id")
  trackingId      String @unique   @map("tracking_id")
  webhookUrl      String?  @map("webhook_url")
  isActive        Boolean  @default(true) @map("is_active")
  lastSyncAt      DateTime? @map("last_sync_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  isBusiness      Boolean  @default(false) @map("is_business")
  
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tracking     Tracking     @relation(fields: [trackingId], references: [id])
  
  @@index([organizationId])
  @@index([status])
  @@map("whatsapp_instances")
}

model InsightShares{
  id String @id @default(cuid())
  name String
  token String @unique @default(cuid()) 
  organizationId String @map("organization_id")
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  filters Json @default("{}") 
  settings Json @default("{}") 
  userId String @map("user_id")
  createdBy User @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("insight_shares")
}

// ─────────────────────────────────────────────
// AGENDA
// ─────────────────────────────────────────────

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

model Agenda {
  id             String   @id @default(cuid())
  name           String
  description    String?
  slug           String  
  isActive       Boolean  @default(true)  @map("is_active")
  slotDuration   Int      @default(30)    @map("slot_duration")
  trackingId     String   @map("tracking_id")
  organizationId String   @map("organization_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt      @map("updated_at")

  tracking     Tracking     @relation(fields: [trackingId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  responsibles         AgendaResponsible[]
  availabilities       AgendaAvailability[]
  appointments         Appointment[]
  publicChatSessions   PublicChatSession[]
  dateOverrides        AgendaDateOverride[]
  dateAvailabilities   AgendaDateAvailability[]

  @@unique([slug, organizationId])
  @@index([trackingId])
  @@index([organizationId])
  @@index([isActive])
  @@map("agendas")
}

// Responsáveis pela agenda (um ou mais usuários)
model AgendaResponsible {
  id        String   @id @default(cuid())
  agendaId  String   @map("agenda_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  agenda Agenda @relation(fields: [agendaId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([agendaId, userId])
  @@index([agendaId])
  @@index([userId])
  @@map("agenda_responsibles")
}

// Disponibilidade por dia da semana (ex: Segunda, 8h–12h)
model AgendaAvailability {
  id        String    @id @default(cuid())
  agendaId  String    @map("agenda_id")
  dayOfWeek DayOfWeek @map("day_of_week")
  isActive  Boolean   @default(true) @map("is_active")

  agenda    Agenda          @relation(fields: [agendaId], references: [id], onDelete: Cascade)
  timeSlots AvailabilityTimeSlot[]

  @@unique([agendaId, dayOfWeek])
  @@index([agendaId])
  @@map("agenda_availabilities")
}

// Intervalos de horário dentro de um dia (ex: 8h–12h, 14h–18h)
model AvailabilityTimeSlot {
  id             String   @id @default(cuid())
  availabilityId String   @map("availability_id")
  startTime      String   @map("start_time") // "08:00"
  endTime        String   @map("end_time")   // "12:00"
  order          Int      @default(0)

  availability AgendaAvailability @relation(fields: [availabilityId], references: [id], onDelete: Cascade)

  @@index([availabilityId])
  @@map("availability_time_slots")
}

// Agendamentos realizados
enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  NO_SHOW
  DONE
}

model Appointment {
  id          String            @id @default(cuid())
  title       String?
  notes       String?
  startsAt    DateTime          @map("starts_at")
  endsAt      DateTime          @map("ends_at")
  status      AppointmentStatus @default(PENDING)
  agendaId    String            @map("agenda_id")
  leadId      String?           @map("lead_id")
  userId      String?           @map("user_id")
  trackingId  String?           @map("tracking_id")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt      @map("updated_at")

  agenda Agenda @relation(fields: [agendaId], references: [id], onDelete: Cascade)
  lead   Lead?  @relation(fields: [leadId], references: [id], onDelete: SetNull)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)
  tracking Tracking? @relation(fields: [trackingId], references: [id], onDelete: SetNull)

  @@index([agendaId])
  @@index([leadId])
  @@index([userId])
  @@index([startsAt])
  @@index([status])
  @@map("appointments")
}

// ─────────────────────────────────────────────
// DISPONIBILIDADE POR DATA ESPECÍFICA
// ─────────────────────────────────────────────

// Disponibilidade para uma data específica (sobrepõe o semanal)
model AgendaDateAvailability {
  id        String   @id @default(cuid())
  agendaId  String   @map("agenda_id")
  date      String   // YYYY-MM-DD
  createdAt DateTime @default(now()) @map("created_at")

  agenda    Agenda                      @relation(fields: [agendaId], references: [id], onDelete: Cascade)
  timeSlots AgendaDateAvailabilitySlot[]

  @@unique([agendaId, date])
  @@index([agendaId])
  @@map("agenda_date_availabilities")
}

// Intervalos de horário dentro de uma disponibilidade por data específica
model AgendaDateAvailabilitySlot {
  id                 String   @id @default(cuid())
  dateAvailabilityId String   @map("date_availability_id")
  startTime          String   @map("start_time") // "08:00"
  endTime            String   @map("end_time")   // "12:00"
  order              Int      @default(0)

  dateAvailability AgendaDateAvailability @relation(fields: [dateAvailabilityId], references: [id], onDelete: Cascade)

  @@index([dateAvailabilityId])
  @@map("agenda_date_availability_slots")
}

// ─────────────────────────────────────────────
// CHAT PÚBLICO DE AGENDAMENTO
// ─────────────────────────────────────────────

// Sessão de chat público — criada quando o cliente abre o chat da agenda.
// Não requer autenticação. Expira em 24h.
model PublicChatSession {
  id            String   @id @default(cuid())
  agendaId      String   @map("agenda_id")
  orgSlug       String   @map("org_slug")
  agendaSlug    String   @map("agenda_slug")
  appointmentId String?  @map("appointment_id")
  createdAt     DateTime @default(now()) @map("created_at")
  expiresAt     DateTime @map("expires_at")

  // Auditoria de segurança
  ipAddress     String?  @map("ip_address")
  userAgent     String?  @map("user_agent")

  agenda Agenda @relation(fields: [agendaId], references: [id], onDelete: Cascade)

  @@index([agendaId])
  @@index([expiresAt])
  @@map("public_chat_sessions")
}

// ─────────────────────────────────────────────
// EXCEÇÕES DE DATA (bloqueios / disponibilidades pontuais)
// ─────────────────────────────────────────────

// Bloqueia ou desbloqueia uma data específica, sobrepondo a disponibilidade semanal.
model AgendaDateOverride {
  id        String   @id @default(cuid())
  agendaId  String   @map("agenda_id")
  date      String   // YYYY-MM-DD
  isBlocked Boolean  @default(true) @map("is_blocked")
  createdAt DateTime @default(now()) @map("created_at")

  agenda Agenda @relation(fields: [agendaId], references: [id], onDelete: Cascade)

  @@unique([agendaId, date])
  @@index([agendaId])
  @@map("agenda_date_overrides")
}

// ─────────────────────────────────────────────
// INTEGRAÇÕES DE PLATAFORMA
// ─────────────────────────────────────────────

enum IntegrationPlatform {
  INSTAGRAM
  TIKTOK
  LINKEDIN
  GMAIL
  GOOGLE_MAPS
  META
  OPENAI
  ANTHROPIC
  GEMINI
  KOMMO
  RD_STATION
  PIPEDRIVE
}

// Armazena credenciais de integração por plataforma/organização.
// O campo config guarda JSON com campos específicos de cada plataforma
// (tokens, IDs, secrets), criptografado em produção via variáveis de ambiente.
model PlatformIntegration {
  id             String              @id @default(cuid())
  platform       IntegrationPlatform
  organizationId String              @map("organization_id")
  isActive       Boolean             @default(false) @map("is_active")
  config         Json                @default("{}") // tokens, IDs, secrets
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt      @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, platform])
  @@index([organizationId])
  @@map("platform_integrations")
}

// ─────────────────────────────────────────────
// WIDGETS
// ─────────────────────────────────────────────

enum WidgetType {
  LEADS_BY_TAG
}

model Widget {
  id             String     @id @default(cuid())
  title          String
  type           WidgetType
  config         Json       @default("{}")
  order          Int        @default(0)
  organizationId String     @map("organization_id")
  createdAt      DateTime   @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("widgets")
}

// ─────────────────────────────────────────────
// FORGE — Propostas & Contratos
// ─────────────────────────────────────────────

enum ForgeProposalStatus {
  RASCUNHO
  ENVIADA
  VISUALIZADA
  PAGA
  EXPIRADA
  CANCELADA
}

enum ForgeContractStatus {
  ATIVO
  ENCERRADO
  CANCELADO
  PENDENTE_ASSINATURA
}

enum ForgePaymentGateway {
  STRIPE
  ASAAS
  PAGBANK
  PAGSEGURO
  MERCADOPAGO
  BANCO_DO_BRASIL
  CAIXA_ECONOMICA
  PIX
}

enum ForgeDiscountType {
  PERCENTUAL
  FIXO
}

enum ForgeSecurityLevel {
  PUBLICO
  PRIVADO
  TWO_FA
}

model ForgeProduct {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  name           String
  sku            String
  imageUrl       String?  @map("image_url")
  unit           String   @default("un")
  description    String?
  value          Decimal  @db.Decimal(15, 2)
  createdById    String   @map("created_by")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt      @map("updated_at")

  organization Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User                  @relation("ForgeProductCreatedBy", fields: [createdById], references: [id])
  proposalProducts ForgeProposalProduct[]

  @@unique([organizationId, sku])
  @@index([organizationId])
  @@map("forge_products")
}

model ForgeProposal {
  id              String               @id @default(cuid())
  organizationId  String               @map("organization_id")
  title           String
  number          Int
  status          ForgeProposalStatus  @default(RASCUNHO)
  clientId        String?              @map("client_id")
  responsibleId   String               @map("responsible_id")
  participants    String[]
  validUntil      DateTime?            @map("valid_until")
  description     String?
  discount        Decimal?             @db.Decimal(15, 2)
  discountType    ForgeDiscountType?   @map("discount_type")
  paymentLink     String?              @map("payment_link")
  paymentGateway  ForgePaymentGateway? @map("payment_gateway")
  publicToken     String               @unique @default(cuid()) @map("public_token")
  headerConfig    Json                 @default("{}") @map("header_config")
  createdById     String               @map("created_by")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt      @map("updated_at")

  organization Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client       Lead?                 @relation(fields: [clientId], references: [id], onDelete: SetNull)
  responsible  User                  @relation("ForgeProposalResponsible", fields: [responsibleId], references: [id])
  createdBy    User                  @relation("ForgeProposalCreatedBy", fields: [createdById], references: [id])
  products     ForgeProposalProduct[]
  contracts    ForgeContract[]

  @@unique([organizationId, number])
  @@index([organizationId])
  @@index([clientId])
  @@index([status])
  @@map("forge_proposals")
}

model ForgeProposalProduct {
  id          String   @id @default(cuid())
  proposalId  String   @map("proposal_id")
  productId   String   @map("product_id")
  quantity    Decimal  @db.Decimal(15, 4) @default(1)
  unitValue   Decimal  @db.Decimal(15, 2) @map("unit_value")
  discount    Decimal? @db.Decimal(15, 2)
  description String?
  order       Int      @default(0)

  proposal ForgeProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  product  ForgeProduct  @relation(fields: [productId], references: [id])

  @@index([proposalId])
  @@map("forge_proposal_products")
}

model ForgeContract {
  id           String              @id @default(cuid())
  proposalId   String?             @map("proposal_id")
  organizationId String            @map("organization_id")
  number       Int
  startDate    DateTime            @map("start_date")
  endDate      DateTime            @map("end_date")
  value        Decimal             @db.Decimal(15, 2)
  status       ForgeContractStatus @default(PENDENTE_ASSINATURA)
  templateId   String?             @map("template_id")
  content      String?
  signers      Json                @default("[]")
  createdById  String              @map("created_by")
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt      @map("updated_at")

  organization Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  proposal     ForgeProposal?          @relation(fields: [proposalId], references: [id], onDelete: SetNull)
  template     ForgeContractTemplate?  @relation(fields: [templateId], references: [id], onDelete: SetNull)
  createdBy    User                    @relation("ForgeContractCreatedBy", fields: [createdById], references: [id])

  @@index([organizationId])
  @@index([proposalId])
  @@index([status])
  @@map("forge_contracts")
}

model ForgeContractTemplate {
  id               String    @id @default(cuid())
  organizationId   String    @map("organization_id")
  name             String
  content          String
  defaultStartDate DateTime? @map("default_start_date")
  defaultEndDate   DateTime? @map("default_end_date")
  createdById      String    @map("created_by")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt      @map("updated_at")

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User             @relation("ForgeTemplateCreatedBy", fields: [createdById], references: [id])
  contracts    ForgeContract[]

  @@index([organizationId])
  @@map("forge_contract_templates")
}

model ForgeSettings {
  id                    String             @id @default(cuid())
  organizationId        String             @unique @map("organization_id")
  commissionPercentage  Decimal            @db.Decimal(5, 2) @default(0) @map("commission_percentage")
  letterheadHeader      String?            @map("letterhead_header")
  letterheadFooter      String?            @map("letterhead_footer")
  letterheadHeaderImage String?            @map("letterhead_header_image")
  letterheadFooterImage String?            @map("letterhead_footer_image")
  logoUrl               String?            @map("logo_url")
  proposalBgColor       String             @default("#ffffff") @map("proposal_bg_color")
  proposalBgImage       String?            @map("proposal_bg_image")
  typographyColor       String             @default("#111111") @map("typography_color")
  securityLevel         ForgeSecurityLevel @default(PUBLICO) @map("security_level")
  reminderDaysBefore    Int                @default(3) @map("reminder_days_before")
  paymentGatewayConfigs Json               @default("{}") @map("payment_gateway_configs")
  createdAt             DateTime           @default(now()) @map("created_at")
  updatedAt             DateTime           @updatedAt      @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("forge_settings")
}

// ─────────────────────────────────────────────
// STARS — sistema de moeda interna
// ─────────────────────────────────────────────

model Plan {
  id            String   @id @default(cuid())
  slug          String   @unique // earth | explore | constellation
  name          String
  monthlyStars  Int      @map("monthly_stars")
  priceMonthly  Decimal  @db.Decimal(10, 2) @map("price_monthly")
  maxUsers      Int      @default(3)       @map("max_users")
  rolloverPct   Int      @default(30)      @map("rollover_pct") // % máx. de rollover
  isActive      Boolean  @default(true)    @map("is_active")
  createdAt     DateTime @default(now())   @map("created_at")

  organizations Organization[]

  @@map("plans")
}

model StarPackage {
  id        String   @id @default(cuid())
  stars     Int
  priceBrl  Decimal  @db.Decimal(10, 2) @map("price_brl")
  label     String
  isActive  Boolean  @default(true)    @map("is_active")
  createdAt DateTime @default(now())   @map("created_at")

  @@map("star_packages")
}

model AppStarCost {
  id           String   @id @default(cuid())
  appSlug      String   @unique @map("app_slug")
  monthlyCost  Int      @default(0) @map("monthly_cost") // stars/mês
  setupCost    Int      @default(0) @map("setup_cost")   // stars na ativação
  priceBrl     Decimal? @db.Decimal(10, 2) @map("price_brl") // exibição R$
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt       @map("updated_at")

  @@map("app_star_costs")
}

enum StarTransactionType {
  PLAN_CREDIT       // crédito mensal do plano
  TOPUP_PURCHASE    // compra de top-up
  APP_CHARGE        // débito mensal de integração
  APP_SETUP         // débito de ativação de integração
  ROLLOVER          // rollover do ciclo anterior
  MANUAL_ADJUST     // ajuste manual (admin)
  REFUND            // estorno
}

model StarTransaction {
  id             String              @id @default(cuid())
  organizationId String              @map("organization_id")
  type           StarTransactionType
  amount         Int                 // positivo = crédito, negativo = débito
  balanceAfter   Int                 @map("balance_after")
  description    String
  appSlug        String?             @map("app_slug")
  packageId      String?             @map("package_id") // ref a StarPackage
  createdAt      DateTime            @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([type])
  @@map("star_transactions")
}

model WorkspaceIntegration {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  appSlug        String   @map("app_slug")
  installedAt    DateTime @default(now()) @map("installed_at")
  lastChargedAt  DateTime? @map("last_charged_at")
  isActive       Boolean  @default(true) @map("is_active")
  config         Json     @default("{}") // credenciais cifradas ou metadata

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, appSlug])
  @@index([organizationId])
  @@map("workspace_integrations")
}

// ─────────────────────────────────────────────
// N-BOX
// ─────────────────────────────────────────────

enum NBoxItemType {
  FILE
  IMAGE
  LINK
  CONTRACT
  PROPOSAL
}

model NBoxFolder {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  name           String
  color          String?
  parentId       String?      @map("parent_id")
  createdById    String       @map("created_by_id")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent         NBoxFolder?  @relation("FolderChildren", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children       NBoxFolder[] @relation("FolderChildren")
  createdBy      User         @relation("NBoxFolderCreatedBy", fields: [createdById], references: [id])
  items          NBoxItem[]

  @@index([organizationId])
  @@index([parentId])
  @@map("nbox_folders")
}

model NBoxItem {
  id               String       @id @default(cuid())
  organizationId   String       @map("organization_id")
  folderId         String?      @map("folder_id")
  type             NBoxItemType
  name             String
  url              String?
  mimeType         String?      @map("mime_type")
  size             Int?
  description      String?
  tags             String[]
  forgeContractId  String?      @map("forge_contract_id")
  forgeProposalId  String?      @map("forge_proposal_id")
  createdById      String       @map("created_by_id")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  folder           NBoxFolder?  @relation(fields: [folderId], references: [id], onDelete: SetNull)
  createdBy        User         @relation("NBoxItemCreatedBy", fields: [createdById], references: [id])

  @@index([organizationId])
  @@index([folderId])
  @@map("nbox_items")
}

// ─── NASA Post ────────────────────────────────────────────────────────────────

enum NasaPostStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  SCHEDULED
  PUBLISHED
  FAILED
}

enum NasaPostType {
  STATIC
  CAROUSEL
  REEL
  STORY
}

model NasaPostBrandConfig {
  id             String   @id @default(cuid())
  organizationId String   @unique @map("organization_id")

  brandName       String   @map("brand_name")
  brandSlogan     String?  @map("brand_slogan")
  website         String?

  icp             String?  @map("icp")
  swot            Json     @default("{}")
  positioning     String?

  toneOfVoice     String?  @map("tone_of_voice")
  keyMessages     String[] @map("key_messages")
  forbiddenWords  String[] @map("forbidden_words")

  primaryColors   String[] @map("primary_colors")
  secondaryColors String[] @map("secondary_colors")
  fonts           Json     @default("{}")

  logoLight       String?  @map("logo_light")
  logoDark        String?  @map("logo_dark")
  logoSquare      String?  @map("logo_square")
  logoHorizontal  String?  @map("logo_horizontal")

  defaultHashtags String[] @map("default_hashtags")
  defaultCtas     String[] @map("default_ctas")
  examplePosts    String[] @map("example_posts")
  showBranding    Boolean  @default(true) @map("show_branding")

  // IA integration keys (stored per-org, never exposed to client)
  anthropicApiKey String?  @map("anthropic_api_key")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("nasa_post_brand_configs")
}

model NasaPost {
  id             String         @id @default(cuid())
  organizationId String         @map("organization_id")
  createdById    String         @map("created_by_id")

  type           NasaPostType   @default(STATIC)
  status         NasaPostStatus @default(DRAFT)

  title          String?
  caption        String?
  hashtags       String[]
  cta            String?

  aiPrompt       String?  @map("ai_prompt")
  starsSpent     Int      @default(0) @map("stars_spent")

  scheduledAt    DateTime? @map("scheduled_at")
  publishedAt    DateTime? @map("published_at")

  targetNetworks String[] @map("target_networks")
  thumbnail      String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User             @relation("NasaPostCreatedBy", fields: [createdById], references: [id])
  slides       NasaPostSlide[]

  @@index([organizationId, status])
  @@index([organizationId, scheduledAt])
  @@map("nasa_posts")
}

model NasaPostSlide {
  id      String @id @default(cuid())
  postId  String @map("post_id")
  order   Int    @default(0)

  imageKey      String?  @map("image_key")
  headline      String?
  subtext       String?
  overlayConfig Json     @default("{}") @map("overlay_config")

  createdAt DateTime @default(now()) @map("created_at")

  post NasaPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, order])
  @@map("nasa_post_slides")
}
// ─── Permissions & Activity ───────────────────────────────────────────────────

model OrgPermission {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           String       // owner(master), admin, member(single), moderador
  appKey         String       @map("app_key")
  canView        Boolean      @default(true)  @map("can_view")
  canCreate      Boolean      @default(true)  @map("can_create")
  canEdit        Boolean      @default(false) @map("can_edit")
  canDelete      Boolean      @default(false) @map("can_delete")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt      @map("updated_at")

  @@unique([organizationId, role, appKey])
  @@index([organizationId])
  @@map("org_permission")
}

model OrgActivityLog {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String       @map("user_id")
  userName       String       @map("user_name")
  userEmail      String       @map("user_email")
  action         String
  resource       String?
  resourceId     String?      @map("resource_id")
  metadata       Json?
  createdAt      DateTime     @default(now()) @map("created_at")

  @@index([organizationId, createdAt])
  @@index([userId])
  @@map("org_activity_log")
}

model SystemActivityLog {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String       @map("user_id")
  userName       String       @map("user_name")
  userEmail      String       @map("user_email")
  userImage      String?      @map("user_image")
  appSlug        String       @default("system") @map("app_slug")
  action         String
  actionLabel    String       @map("action_label")
  resource       String?
  resourceId     String?      @map("resource_id")
  metadata       Json?
  createdAt      DateTime     @default(now()) @map("created_at")

  @@index([organizationId, createdAt])
  @@index([userId])
  @@index([appSlug])
  @@map("system_activity_log")
}

model UserPresence {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String       @map("user_id")
  userName       String       @map("user_name")
  userEmail      String       @map("user_email")
  userImage      String?      @map("user_image")
  lastSeenAt     DateTime     @default(now()) @map("last_seen_at")

  @@unique([userId, organizationId])
  @@map("user_presence")
}
