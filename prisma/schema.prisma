generator client {
  provider      = "prisma-client"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    String    @id @default(cuid())
  name                  String
  email                 String
  emailVerified         Boolean   @default(false)
  nickname              String?
  phone                 String?
  image                 String?
  isSystemAdmin         Boolean   @default(false) @map("is_system_admin")
  isActive              Boolean   @default(true) @map("is_active")
  onboardingCompletedAt DateTime? @map("onboarding_completed_at")
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @default(now()) @updatedAt
  sessions              Session[]
  accounts              Account[]

  members                            Member[]
  invitations                        Invitation[]
  inviteLinksCreated                 OrganizationInviteLink[]     @relation("InviteLinksCreated")
  trackings                          TrackingParticipant[]
  leadHistories                      LeadHistory[]
  participantOnActions               ActionsUserParticipant[]
  responsibleOnActions               ActionsUserResponsible[]
  actions                            Action[]
  responsibleOnSubActions            SubActionUserResponsible[]
  responsibleOnLeads                 Lead[]                       @relation("LeadResponsible")
  worflows                           Workflow[]
  forms                              Form[]
  leadFiles                          LeadFile[]
  insightShares                      InsightShares[]
  agendaResponsibles                 AgendaResponsible[]
  appointments                       Appointment[]
  trackingConsultants                TrackingConsultant[]
  forgeProductsCreated               ForgeProduct[]               @relation("ForgeProductCreatedBy")
  forgeProposalsResp                 ForgeProposal[]              @relation("ForgeProposalResponsible")
  forgeProposalsCreated              ForgeProposal[]              @relation("ForgeProposalCreatedBy")
  forgeContractsCreated              ForgeContract[]              @relation("ForgeContractCreatedBy")
  forgeTemplatesCreated              ForgeContractTemplate[]      @relation("ForgeTemplateCreatedBy")
  nboxFoldersCreated                 NBoxFolder[]                 @relation("NBoxFolderCreatedBy")
  nboxItemsCreated                   NBoxItem[]                   @relation("NBoxItemCreatedBy")
  nasaPlannerPostsCreated            NasaPlannerPost[]            @relation("NasaPlannerPostCreatedBy")
  actionSharesRequested              ActionShare[]                @relation("ShareRequester")
  workspacesCreated                  Workspace[]
  workspacesMembers                  WorkspaceMember[]
  userNotifications                  UserNotification[]
  notificationPrefs                  UserNotificationPreference[]
  sidebarPrefs                       UserSidebarPreference[]
  spacePoints                        UserSpacePoint[]
  memberStarBudgets                  MemberStarBudget[]
  paymentEntriesCreated              PaymentEntry[]               @relation("PaymentEntryCreatedBy")
  paymentAccess                      PaymentAccess[]              @relation("PaymentAccessUser")
  paymentAccessGranted               PaymentAccess[]              @relation("PaymentAccessAuthorizer")
  nasaCampaignPlannersCreated        NasaCampaignPlanner[]        @relation("NasaCampaignPlannerCreatedBy")
  nasaCampaignOnboardingsResponsible NasaCampaignOnboarding[]     @relation("NasaCampaignOnboardingResponsible")
  nasaCampaignTasksAssigned          NasaCampaignTask[]           @relation("NasaCampaignTaskAssignee")
  supportTickets                     SupportTicket[]
  stripeCustomerId                   String?                      @map("stripe_customer_id")

  linnkerPages           LinnkerPage[]
  spaceStation           SpaceStation?
  stationAccessRequests  StationAccessRequest[]
  worldTemplates         WorldTemplate[]
  avatarTemplates        AvatarTemplate[]
  connectionsAsUser      UserConnection[]       @relation("UserConnectionsAsUser")
  connectionsAsConnected UserConnection[]       @relation("UserConnectionsAsConnected")
  nasaPages              NasaPage[]
  actionLikes            ActionLike[]
  publicActionShares     PublicActionShare[]    @relation("PublicActionShareSharer")
  actionReminders        ActionReminder[]       @relation("ActionReminderUser")

  profileCard                UserProfileCard?
  orgRoles                   OrgRole[]
  orgFollows                 OrgFollow[]
  companyReviews             CompanyReview[]
  companyPosts               CompanyPost[]
  companyPostComments        CompanyPostComment[]
  spaceHelpProgress          SpaceHelpProgress[]
  spaceHelpBadges            UserSpaceHelpBadge[]
  nasaRouteCoursesCreated    NasaRouteCourse[]      @relation("NasaRouteCreatorUser")
  nasaRouteEnrollments       NasaRouteEnrollment[]
  nasaRouteProgress          NasaRouteProgress[]
  nasaRouteFreeAccess        NasaRouteFreeAccess[]  @relation("NasaRouteFreeAccessUser")
  nasaRouteFreeAccessGranted NasaRouteFreeAccess[]  @relation("NasaRouteFreeAccessGrantor")
  nasaRouteCertificates      NasaRouteCertificate[]
  remindersCreated           Reminder[]             @relation("ReminderCreatedBy")

  // ── NASA Partner ──
  referralLink                  PartnerReferralLink?
  partner                       Partner?
  partnerReferralsCreated       PartnerReferral[]     @relation("PartnerReferralsAsPartner")
  partnerReferralsAttachedByMe  PartnerReferral[]     @relation("PartnerReferralsAttachedByAdmin")
  partnerTermsVersionsPublished PartnerTermsVersion[] @relation("PartnerTermsVersionPublisher")
  partnerTierHistoryTriggered   PartnerTierHistory[]  @relation("PartnerTierHistoryTrigger")
  partnerPayoutsMarkedPaid      PartnerPayout[]       @relation("PartnerPayoutPaidBy")

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  activeOrganizationId String?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Organization {
  id           String   @id @default(cuid())
  name         String
  slug         String
  logo         String?
  createdAt    DateTime
  metadata     String?
  companyCode  String?  @unique @map("company_code")
  companyNiche String?  @map("company_niche")
  companyCep   String?  @map("company_cep")

  // ── STARS ──────────────────────────────────
  planId               String?   @map("plan_id")
  starsBalance         Int       @default(0) @map("stars_balance")
  starsCycleStart      DateTime? @map("stars_cycle_start")
  starsAlertConfig     Json      @default("{}") @map("stars_alert_config")
  starDistributionMode String    @default("org") @map("star_distribution_mode")
  // "org"    = pool compartilhado (padrão)
  // "equal"  = dividido igualmente entre usuários ativos
  // "custom" = orçamento personalizado por usuário

  members                Member[]
  invitations            Invitation[]
  inviteLinks            OrganizationInviteLink[]
  trackings              Tracking[]
  tags                   Tag[]
  whatsappInstances      WhatsAppInstance[]
  actions                Action[]
  insightShares          InsightShares[]
  agendas                Agenda[]
  widgets                Widget[]
  platformIntegrations   PlatformIntegration[]
  forgeProducts          ForgeProduct[]
  forgeProposals         ForgeProposal[]
  forgeContracts         ForgeContract[]
  forgeTemplates         ForgeContractTemplate[]
  forgeSettings          ForgeSettings?
  plan                   Plan?                    @relation(fields: [planId], references: [id], onDelete: SetNull)
  starTransactions       StarTransaction[]
  workspaceIntegrations  WorkspaceIntegration[]
  memberStarBudgets      MemberStarBudget[]
  nboxFolders            NBoxFolder[]
  nboxItems              NBoxItem[]
  nasaPlanners           NasaPlanner[]
  orgPermissions         OrgPermission[]
  activityLogs           OrgActivityLog[]
  systemActivityLogs     SystemActivityLog[]
  userPresences          UserPresence[]
  workspaces             Workspace[]
  form                   Form[]
  workspaceFolders       WorkspaceFolder[]
  sentShares             ActionShare[]            @relation("SentShares")
  receivedShares         ActionShare[]            @relation("ReceivedShares")
  starRules              StarRule[]
  spacePoints            UserSpacePoint[]
  spacePointTransactions SpacePointTransaction[]
  spacePointPrizes       SpacePointRankingPrize[]

  // NASA Payment
  paymentBankAccounts PaymentBankAccount[]
  paymentCategories   PaymentCategory[]
  paymentCostCenters  PaymentCostCenter[]
  paymentContacts     PaymentContact[]
  paymentEntries      PaymentEntry[]
  paymentAccess       PaymentAccess[]

  // NASA Campaign Planner
  nasaCampaignPlanners NasaCampaignPlanner[]

  // Projetos / Clientes
  orgProjects OrgProject[]

  // Client Onboarding
  clientOnboardingProcesses ClientOnboardingProcess[]

  // Linnker
  linnkerPages LinnkerPage[]

  // NASA Pages
  nasaPages NasaPage[]

  // Space Station
  spaceStation SpaceStation?

  // Marca / Brand
  brandSlogan         String? @map("brand_slogan")
  brandWebsite        String? @map("brand_website")
  brandIcp            String? @map("brand_icp")
  brandPositioning    String? @map("brand_positioning")
  brandVoiceTone      String? @map("brand_voice_tone")
  brandVisual         Json    @default("{}") @map("brand_visual")
  brandAiInstructions String? @map("brand_ai_instructions")
  brandSwot           Json    @default("{}") @map("brand_swot")

  // ── Localização (para diretório Empresas no mapa) ──
  addressLine String?   @map("address_line")
  city        String?
  state       String?
  postalCode  String?   @map("postal_code")
  country     String?   @default("BR")
  latitude    Float?
  longitude   Float?
  geocodedAt  DateTime? @map("geocoded_at")

  companyType                 String?               @map("company_type") // slug ex: "agencia-publicidade" — vide src/features/company/constants.ts
  companySegment              String?               @map("company_segment") // texto livre opcional (sub-nicho)
  cnpj                        String?
  contactEmail                String?               @map("contact_email")
  contactPhone                String?               @map("contact_phone")
  bio                         String?
  bannerUrl                   String?               @map("banner_url")
  website                     String?
  isSpacehomePublic           Boolean               @default(false) @map("is_spacehome_public")
  spacehomeTemplate           String?               @default("default") @map("spacehome_template")
  nasaPageId                  String?               @unique @map("nasa_page_id")
  nasaPage                    NasaPage?             @relation("OrgSpacehome", fields: [nasaPageId], references: [id], onDelete: SetNull)
  orgRoles                    OrgRole[]
  orgFollows                  OrgFollow[]
  companyReviews              CompanyReview[]
  companyPosts                CompanyPost[]
  spacehomeAuditLogs          SpacehomeAuditLog[]
  nasaRouteCoursesCreated     NasaRouteCourse[]     @relation("NasaRouteCreatorOrg")
  nasaRouteEnrollmentsAsBuyer NasaRouteEnrollment[] @relation("NasaRouteBuyerOrg")
  nasaRouteFreeAccess         NasaRouteFreeAccess[] @relation("NasaRouteFreeAccessOrg")

  // ── NASA Partner ──
  partnerReferral        PartnerReferral?
  partnerCommissions     PartnerCommission[]
  partnerLifetimeGranted Boolean             @default(false) @map("partner_lifetime_granted")

  @@unique([slug])
  @@map("organization")
}

model Member {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String
  cargo          String?      @map("cargo")
  createdAt      DateTime

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
  @@map("member")
}

model Invitation {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           String?
  status         String
  expiresAt      DateTime
  inviterId      String
  user           User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([organizationId])
  @@index([email])
  @@map("invitation")
}

model OrganizationInviteLink {
  id             String    @id @default(cuid())
  organizationId String
  token          String    @unique
  role           String    @default("member")
  expiresAt      DateTime
  createdById    String
  revokedAt      DateTime?
  usesCount      Int       @default(0)
  starsOnJoin    Int       @default(0)
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User         @relation("InviteLinksCreated", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([token])
  @@map("organization_invite_link")
}

// ─────────────────────────────────────────────
// TRACKING
// ─────────────────────────────────────────────

model Tracking {
  id                        String    @id @default(cuid())
  name                      String
  description               String?
  organizationId            String    @map("organization_id")
  orgProjectId              String?   @map("org_project_id")
  isArchived                Boolean   @default(false) @map("is_archived")
  archivedAt                DateTime? @map("archived_at")
  globalAiActive            Boolean   @default(false) @map("global_ai_active")
  isTemplate                Boolean   @default(false) @map("is_template")
  templateMarkedByModerator Boolean   @default(false) @map("template_marked_by_moderator")
  createdAt                 DateTime  @default(now()) @map("created_at")
  updatedAt                 DateTime  @updatedAt @map("updated_at")

  // Relacionamentos
  organization        Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  orgProject          OrgProject?           @relation(fields: [orgProjectId], references: [id], onDelete: SetNull)
  participants        TrackingParticipant[]
  status              Status[]
  leads               Lead[]
  tags                Tag[]
  winLossReasons      WinLossReason[]
  actions             Action[]
  workflows           Workflow[]
  forms               FormSettings[]
  whatsappInstance    WhatsAppInstance?
  conversations       Conversation[]
  agendas             Agenda[]
  appointments        Appointment[]
  aiSettings          AiSettings?
  trackingConsultants TrackingConsultant[]
  workspaces          Workspace[]
  scripts             Script[]
  reminders           Reminder[]

  @@map("tracking")
}

model AiSettings {
  id             String  @id @default(cuid())
  prompt         String
  assistantName  String? @map("assistant_name")
  finishSentence String? @map("finish_sentence")
  isAudioEnabled Boolean @default(false) @map("is_audio_enabled")

  trackingId String   @unique
  tracking   Tracking @relation(fields: [trackingId], references: [id])

  @@map("ai_setting")
}

enum ReasonType {
  WIN // Ganho
  LOSS // Perda
}

enum TagType {
  CUSTOM
  SYSTEM
}

model WinLossReason {
  id         String     @id @default(cuid())
  name       String
  type       ReasonType // GANHO ou PERDA
  trackingId String     @map("tracking_id")
  isActive   Boolean    @default(true) @map("is_active")
  order      Int        @default(0)
  createdAt  DateTime   @default(now()) @map("created_at")

  tracking      Tracking      @relation(fields: [trackingId], references: [id], onDelete: Cascade)
  leadHistories LeadHistory[]

  @@index([trackingId])
  @@map("win_loss_reasons")
}

model TrackingConsultant {
  id         String  @id @default(cuid())
  trackingId String  @map("tracking_id")
  userId     String  @map("user_id")
  maxFlow    Int     @default(0) @map("max_flow")
  isActive   Boolean @default(true)

  tracking Tracking @relation(fields: [trackingId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, trackingId])
  @@map("tracking_consultant")
}

model TrackingParticipant {
  id         String          @id @default(cuid())
  userId     String          @map("user_id")
  trackingId String          @map("tracking_id")
  role       ParticipantRole @default(MEMBER)
  createdAt  DateTime        @default(now()) @map("created_at")
  tracking   Tracking        @relation(fields: [trackingId], references: [id], onDelete: Cascade)
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, trackingId])
  @@map("tracking_participant")
}

enum ParticipantRole {
  OWNER // Criador, controle total
  ADMIN // Pode gerenciar participantes
  MEMBER // Pode visualizar e interagir
  VIEWER // Apenas visualização
}

model Status {
  id         String   @id @default(cuid())
  name       String
  color      String?  @default("#1447e6")
  order      Decimal  @default(0) @db.Decimal(20, 10)
  trackingId String   @map("tracking_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Relacionamentos
  tracking     Tracking       @relation(fields: [trackingId], references: [id], onDelete: Cascade)
  leads        Lead[]
  FormSettings FormSettings[]

  @@index([trackingId, order])
  @@map("status")
}

enum LeadAction {
  ACTIVE // Lead ativo no funil
  DELETED // Excluído (lixeira)
  WON // Ganho
  LOST // Perdido
}

model LeadHistory {
  id        String     @id @default(cuid())
  leadId    String     @map("lead_id")
  action    LeadAction
  reasonId  String?    @map("reason_id")
  notes     String?
  userId    String     @map("user_id")
  createdAt DateTime   @default(now()) @map("created_at")

  // Relacionamentos
  lead   Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  reason WinLossReason? @relation(fields: [reasonId], references: [id], onDelete: SetNull)
  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([action])
  @@index([createdAt])
  @@map("lead_history")
}

enum LeadSource {
  DEFAULT
  WHATSAPP
  FORM
  AGENDA
  INSTAGRAM
  TIKTOK
  LINKEDIN
  GMAIL
  GOOGLE_MAPS
  OTHER
}

enum Temperature {
  COLD
  WARM
  HOT
  VERY_HOT
}

enum StatusFlow {
  NEW
  ACTIVE
  WAITING
  FINISHED
}

model Lead {
  id            String      @id @default(cuid())
  name          String
  email         String?
  phone         String?
  document      String?
  profile       String?
  description   String?
  statusId      String      @map("status_id")
  trackingId    String      @map("tracking_id")
  responsibleId String?     @map("responsible_id")
  orgProjectId  String?     @map("org_project_id")
  order         Decimal     @default(0) @db.Decimal(20, 10)
  source        LeadSource  @default(DEFAULT)
  temperature   Temperature @default(COLD)
  amount        Decimal     @default(0) @db.Decimal(15, 2)
  statusFlow    StatusFlow  @default(ACTIVE) @map("status_flow")

  currentAction LeadAction @default(ACTIVE) @map("current_action")
  isActive      Boolean    @default(true) @map("is_active")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  closedAt  DateTime? @map("closed_at")

  // Relacionamentos
  status      Status      @relation(fields: [statusId], references: [id], onDelete: Cascade)
  tracking    Tracking    @relation(fields: [trackingId], references: [id], onDelete: Cascade)
  responsible User?       @relation("LeadResponsible", fields: [responsibleId], references: [id], onDelete: SetNull)
  orgProject  OrgProject? @relation(fields: [orgProjectId], references: [id], onDelete: SetNull)

  conversation Conversation?
  reminders    Reminder[]

  leadTags                  LeadTag[]
  history                   LeadHistory[]
  files                     LeadFile[]
  actions                   Action[]
  appointments              Appointment[]
  forgeProposals            ForgeProposal[]
  formResponses             FormResponses[]
  clientOnboardingProcesses ClientOnboardingProcess[]
  linnkerScans              LinnkerScan[]

  @@unique([phone, trackingId])
  @@index([trackingId])
  @@index([statusId, order])
  @@index([email])
  @@index([phone])
  @@index([createdAt])
  @@index([currentAction])
  @@index([isActive])
  @@index([responsibleId])
  @@map("leads")
}

model Tag {
  id             String   @id @default(cuid())
  name           String
  slug           String
  color          String?  @default("#1447e6")
  description    String?
  icon           String?
  type           TagType  @default(CUSTOM)
  organizationId String   @map("organization_id")
  trackingId     String?  @map("tracking_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  whatsappId String? @map("whatsapp_id")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tracking     Tracking?    @relation(fields: [trackingId], references: [id], onDelete: Cascade)
  leadTags     LeadTag[]

  // 👈 Importante: nome único por contexto
  @@unique([slug, organizationId, trackingId])
  @@unique([name, organizationId, trackingId])
  @@index([organizationId])
  @@index([trackingId])
  @@map("tags")
}

model LeadTag {
  id        String   @id @default(cuid())
  leadId    String   @map("lead_id")
  tagId     String   @map("tag_id")
  createdAt DateTime @default(now()) @map("created_at")

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([leadId, tagId])
  @@index([leadId])
  @@index([tagId])
  @@map("lead_tags")
}

model LeadFile {
  id        String   @id @default(cuid())
  leadId    String   @map("lead_id")
  fileUrl   String   @map("file_url")
  mimeType  String   @map("mime_type")
  createdAt DateTime @default(now()) @map("created_at")
  name      String

  createdBy String? @map("created_by")
  creator   User?   @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  lead      Lead    @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([createdBy])
  @@map("lead_files")
}

// ─────────────────────────────────────────────
// WOKSPACE
// ─────────────────────────────────────────────

enum WorkspaceMemberRole {
  OWNER
  MEMBER
  VIEWER
}

enum ActionPriority {
  NONE
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum EventCategory {
  WORKSHOP
  PALESTRA
  LANCAMENTO
  WEBINAR
  NETWORKING
  CURSO
  REUNIAO
  HACKATHON
  CONFERENCIA
  OUTRO
}

enum ReminderChannel {
  WHATSAPP
  EMAIL
}

model Workspace {
  id                        String  @id @default(cuid())
  name                      String
  description               String?
  color                     String? @default("#1447e6")
  icon                      String?
  coverImage                String?
  isArchived                Boolean @default(false) @map("is_archived")
  order                     Int     @default(0)
  isTemplate                Boolean @default(false) @map("is_template")
  templateMarkedByModerator Boolean @default(false) @map("template_marked_by_moderator")

  organizationId String  @map("organization_id")
  trackingId     String? @map("tracking_id") // opcional
  orgProjectId   String? @map("org_project_id")
  createdBy      String  @map("created_by")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tracking     Tracking?    @relation(fields: [trackingId], references: [id], onDelete: SetNull)
  orgProject   OrgProject?  @relation(fields: [orgProjectId], references: [id], onDelete: SetNull)
  creator      User         @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  columns WorkspaceColumn[]
  members WorkspaceMember[]
  actions Action[]

  backgroundImage String?               @map("background_image")
  backgroundColor String?               @map("background_color")
  visibility      String                @default("PRIVATE") @map("visibility")
  archivedAt      DateTime?             @map("archived_at")
  tags            WorkspaceTag[]
  automations     WorkspaceAutomation[]
  workflows       Workflow[]
  folderItems     WorkspaceFolderItem[]

  @@index([organizationId])
  @@index([trackingId])
  @@index([createdBy])
  @@index([isArchived])
  @@map("workspaces")
}

model WorkspaceColumn {
  id          String  @id @default(cuid())
  name        String
  color       String? @default("#1447e6")
  order       Decimal @default(0) @db.Decimal(20, 10)
  workspaceId String  @map("workspace_id")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  actions   Action[]

  @@index([workspaceId, order])
  @@map("workspace_columns")
}

model WorkspaceMember {
  id          String              @id @default(cuid())
  workspaceId String              @map("workspace_id")
  userId      String              @map("user_id")
  role        WorkspaceMemberRole @default(MEMBER)
  createdAt   DateTime            @default(now()) @map("created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
  @@map("workspace_members")
}

model ActionsUserParticipant {
  id        String   @id @default(cuid())
  actionId  String   @map("action_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  action Action @relation(fields: [actionId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([actionId, userId])
  @@index([userId])
}

model ActionsUserResponsible {
  id       String @id @default(cuid())
  actionId String @map("action_id")
  userId   String @map("user_id")

  action Action @relation(fields: [actionId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([actionId, userId])
  @@map("actions_user_responsibles")
}

enum TypeAction {
  TASK
  ACTION
  MEETING
  NOTE
}

model Action {
  id          String         @id @default(cuid())
  title       String
  description String?
  score       Int            @default(0)
  isDone      Boolean        @default(false) @map("is_done")
  type        TypeAction     @default(TASK)
  priority    ActionPriority @default(NONE)
  order       Decimal        @default(0) @db.Decimal(20, 10)
  dueDate     DateTime?      @map("due_date")
  startDate   DateTime?      @map("start_date")
  endDate     DateTime?      @map("end_date")

  workspaceId String  @map("workspace_id")
  columnId    String? @map("column_id")

  trackingId     String? @map("tracking_id")
  organizationId String? @map("organization_id")
  createdBy      String  @map("created_by")
  leadId         String? @map("lead_id")
  orgProjectId   String? @map("org_project_id")

  closedAt  DateTime? @map("closed_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user         User             @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  lead         Lead?            @relation(fields: [leadId], references: [id], onDelete: SetNull)
  tracking     Tracking?        @relation(fields: [trackingId], references: [id], onDelete: SetNull)
  organization Organization?    @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  orgProject   OrgProject?      @relation(fields: [orgProjectId], references: [id], onDelete: SetNull)
  workspace    Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  column       WorkspaceColumn? @relation(fields: [columnId], references: [id], onDelete: SetNull)

  participants ActionsUserParticipant[]
  responsibles ActionsUserResponsible[]
  subActions   SubActions[]

  attachments     Json           @default("[]") @map("attachments")
  links           Json           @default("[]") @map("links")
  youtubeUrl      String?        @map("youtube_url")
  coverImage      String?        @map("cover_image")
  isArchived      Boolean        @default(false) @map("is_archived")
  isFavorited     Boolean        @default(false) @map("is_favorited")
  history         Json           @default("[]") @map("history")
  tags            ActionTag[]
  mirrorsAsSource ActionMirror[] @relation("SourceMirror")
  mirrorOf        ActionMirror?  @relation("MirrorOf")
  sharedFrom      ActionShare[]  @relation("SharedAction")

  // ─── Calendário Público ─────────────────────────────────────────────
  isPublic    Boolean   @default(false) @map("is_public")
  publicSlug  String?   @unique @map("public_slug")
  publishedAt DateTime? @map("published_at")

  viewCount  Int @default(0) @map("view_count")
  likesCount Int @default(0) @map("likes_count")
  shareCount Int @default(0) @map("share_count")

  country String? @default("BR")
  state   String?
  city    String?
  address String?

  eventCategory   EventCategory? @map("event_category")
  registrationUrl String?        @map("registration_url")
  formId          String?        @map("form_id")

  isGuestDraft    Boolean @default(false) @map("is_guest_draft")
  guestDraftToken String? @unique @map("guest_draft_token")

  likes        ActionLike[]
  views        ActionView[]
  publicShares PublicActionShare[]
  reminders    ActionReminder[]

  @@index([workspaceId])
  @@index([columnId])
  @@index([leadId])
  @@index([createdBy])
  @@index([isDone])
  @@index([priority])
  @@index([dueDate])
  @@index([order])
  @@index([isPublic, publishedAt])
  @@index([country, state, city])
  @@index([eventCategory])
  @@index([organizationId, isPublic, publishedAt])
  @@map("actions")
}

// ─── Calendário Público: Likes / Views / Shares / Reminders ─────────────────

model ActionLike {
  id          String   @id @default(cuid())
  actionId    String   @map("action_id")
  userId      String?  @map("user_id")
  fingerprint String?
  createdAt   DateTime @default(now()) @map("created_at")

  action Action @relation(fields: [actionId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([actionId, userId])
  @@unique([actionId, fingerprint])
  @@index([actionId])
  @@index([userId])
  @@map("action_likes")
}

model ActionView {
  id          String   @id @default(cuid())
  actionId    String   @map("action_id")
  fingerprint String
  userId      String?  @map("user_id")
  referrer    String?
  sharerToken String?  @map("sharer_token")
  createdAt   DateTime @default(now()) @map("created_at")

  action Action @relation(fields: [actionId], references: [id], onDelete: Cascade)

  @@unique([actionId, fingerprint])
  @@index([actionId, createdAt])
  @@index([sharerToken])
  @@map("action_views")
}

model PublicActionShare {
  id           String   @id @default(cuid())
  actionId     String   @map("action_id")
  sharerUserId String?  @map("sharer_user_id")
  sharerToken  String   @unique @map("sharer_token")
  platform     String?
  clicks       Int      @default(0)
  createdAt    DateTime @default(now()) @map("created_at")

  action     Action @relation(fields: [actionId], references: [id], onDelete: Cascade)
  sharerUser User?  @relation("PublicActionShareSharer", fields: [sharerUserId], references: [id], onDelete: SetNull)

  @@index([actionId])
  @@index([sharerUserId])
  @@map("public_action_shares")
}

model ActionReminder {
  id          String          @id @default(cuid())
  actionId    String          @map("action_id")
  userId      String?         @map("user_id")
  phoneNumber String          @map("phone_number")
  channel     ReminderChannel @default(WHATSAPP)
  remindAt    DateTime        @map("remind_at")
  sent        Boolean         @default(false)
  sentAt      DateTime?       @map("sent_at")
  consentAt   DateTime        @default(now()) @map("consent_at")
  createdAt   DateTime        @default(now()) @map("created_at")

  action Action @relation(fields: [actionId], references: [id], onDelete: Cascade)
  user   User?  @relation("ActionReminderUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([actionId, sent])
  @@index([remindAt, sent])
  @@map("action_reminders")
}

model SubActionUserResponsible {
  id          String @id @default(cuid())
  userId      String @map("user_id")
  subActionId String @map("sub_action_id")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  subAction SubActions @relation(fields: [subActionId], references: [id], onDelete: Cascade)

  @@unique([userId, subActionId])
  @@map("sub_actions_user_responsible")
}

model SubActions {
  id           String                     @id @default(cuid())
  title        String
  description  String?
  isDone       Boolean                    @default(false) @map("is_done")
  finishDate   DateTime?                  @map("finish_date")
  createdAt    DateTime                   @default(now()) @map("created_at")
  actionId     String                     @map("action_id")
  action       Action                     @relation(fields: [actionId], references: [id])
  responsibles SubActionUserResponsible[]

  @@index([actionId])
  @@index([isDone])
  @@index([finishDate])
  @@map("sub_action")
}

// ─────────────────────────────────────────────
// AUTOMAÇÕES
// ─────────────────────────────────────────────

model Workflow {
  id          String   @id @default(cuid())
  name        String
  description String?
  userId      String?  @map("user_id")
  trackingId  String?  @map("tracking_id")
  workspaceId String?  @map("workspace_id")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user      User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  tracking  Tracking?  @relation(fields: [trackingId], references: [id], onDelete: Cascade)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  nodes       Node[]
  connections Connection[]

  @@index([trackingId])
  @@index([workspaceId])
  @@map("workflows")
}

enum NodeType {
  // Gatilhos
  INITIAL
  MANUAL_TRIGGER
  NEW_LEAD
  MOVE_LEAD_STATUS
  LEAD_TAGGED
  AI_FINISHED
  // LEAD_UNTAGGED

  // Execuções
  HTTP_REQUEST
  MOVE_LEAD
  SEND_MESSAGE
  WAIT
  WIN_LOSS
  TAG
  TEMPERATURE
  RESPONSIBLE

  // Utils
  FILTER_LEAD

  // ─── Workspace (Actions/Kanban) ─────────────────
  // Utils
  WS_INITIAL

  // Gatilhos
  WS_MANUAL_TRIGGER
  WS_ACTION_CREATED
  WS_ACTION_MOVED_COLUMN
  WS_ACTION_TAGGED
  WS_ACTION_COMPLETED
  WS_ACTION_PARTICIPANT_ADDED

  // Execuções
  WS_CREATE_ACTION
  WS_MOVE_ACTION
  WS_ADD_TAG_ACTION
  WS_ADD_PARTICIPANT
  WS_SET_RESPONSIBLE
  WS_CREATE_SUB_ACTION
  WS_SEND_MESSAGE_PARTICIPANTS
  WS_SEND_EMAIL_PARTICIPANTS
  WS_ARCHIVE_ACTION
  WS_WAIT
  WS_HTTP_REQUEST
  WS_FILTER
}

model Node {
  id         String   @id @default(cuid())
  workflowId String   @map("workflow_id")
  name       String
  type       NodeType
  position   Json
  data       Json     @default("{}")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  outputConnections Connection[] @relation("FromNode")
  inputConnections  Connection[] @relation("ToNode")

  @@map("nodes")
}

model Connection {
  id         String   @id @default(cuid())
  workflowId String   @map("workflow_id")
  fromNodeId String   @map("from_node_id")
  toNodeId   String   @map("to_node_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  fromOutput String   @default("main")
  toInput    String   @default("main")

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  fromNode Node     @relation("FromNode", fields: [fromNodeId], references: [id], onDelete: Cascade)
  toNode   Node     @relation("ToNode", fields: [toNodeId], references: [id], onDelete: Cascade)

  @@unique([fromNodeId, toNodeId, fromOutput, toInput])
  @@map("connections")
}

// ─────────────────────────────────────────────
// FORMULÁRIO
// ─────────────────────────────────────────────

model Form {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  organizationId String
  name           String
  description    String?
  jsonBlock      String   @default("[]")
  published      Boolean  @default(false)
  content        String
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  settingsId     String?  @unique

  views     Int @default(0)
  responses Int @default(0)

  isTemplate                Boolean @default(false) @map("is_template")
  templateMarkedByModerator Boolean @default(false) @map("template_marked_by_moderator")

  createdBy       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  formSubmissions FormResponses[]
  shareUrl        String          @unique @map("share_url")

  organization Organization  @relation(fields: [organizationId], references: [id])
  settings     FormSettings?

  onboardingBrandForms      ClientOnboardingProcess[] @relation("OnboardingBrandForm")
  onboardingOnboardingForms ClientOnboardingProcess[] @relation("OnboardingOnboardingForm")

  isPublicOnSpace Boolean @default(false) @map("is_public_on_space")

  @@map("forms")
}

model FormSettings {
  id              String   @id @default(cuid())
  primaryColor    String
  backgroundColor String
  backgroundImage String?  @map("background_image")
  createdAt       DateTime @default(now())
  updateAt        DateTime @default(now()) @updatedAt
  trackingId      String?  @map("tracking_id")
  statusId        String?  @map("status_id")
  formId          String   @unique
  redirectUrl     String?  @map("redirect_url")
  idPixel         String?  @map("id_pixel")
  idTagManager    String?  @map("id_tag_manager")
  needLogin       Boolean  @default(true) @map("need_login")
  showName        Boolean  @default(true) @map("show_name")
  showEmail       Boolean  @default(true) @map("show_email")
  showPhone       Boolean  @default(true) @map("show_phone")
  finishMessage   String   @default("Obrigado por seu cadastro!") @map("finish_message")

  tracking Tracking? @relation(fields: [trackingId], references: [id], onDelete: SetNull)
  status   Status?   @relation(fields: [statusId], references: [id], onDelete: SetNull)
  form     Form      @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@map("form_settings")
}

model FormResponses {
  id           String   @id @default(cuid())
  formId       String   @map("form_id")
  createdAt    DateTime @default(now()) @map("created_at")
  jsonResponse Json     @default("[]")
  leadId       String?  @map("lead_id")
  lead         Lead?    @relation(fields: [leadId], references: [id])

  form Form @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@map("form_responses")
}

// ─────────────────────────────────────────────
// CHAT
// ─────────────────────────────────────────────

enum MessageChannel {
  WHATSAPP
  INSTAGRAM
  FACEBOOK
}

model Conversation {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now()) @map("created_at")
  lastMessageAt DateTime @updatedAt @map("last_message_at")
  name          String?
  isGroup       Boolean  @default(false)

  remoteJid     String         @map("remote_jid")
  profilePicUrl String?        @map("profile_pic_url")
  isActive      Boolean        @default(true) @map("is_active")
  channel       MessageChannel @default(WHATSAPP) @map("channel")

  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId     String   @unique @map("lead_id")
  trackingId String   @map("tracking_id")
  tracking   Tracking @relation(fields: [trackingId], references: [id], onDelete: Cascade)

  lastMessageId String?  @unique @map("last_message_id")
  lastMessage   Message? @relation(fields: [lastMessageId], references: [id])

  messages  Message[]  @relation("Messages")
  reminders Reminder[]

  @@unique([leadId, trackingId])
  @@unique([remoteJid, trackingId])
  @@index([isActive])
  @@index([lastMessageAt])
  @@index([trackingId])
  @@map("conversations")
}

enum MessageStatus {
  SENT
  SEEN
  DELETED
}

model Message {
  id        String   @id @default(cuid())
  body      String?
  createdAt DateTime @default(now()) @map("created_at")

  messageId String        @unique @map("message_id")
  fromMe    Boolean       @default(false) @map("from_me")
  status    MessageStatus @default(SENT)
  seen      Boolean       @default(false)

  mediaUrl     String? @map("media_url")
  mediaType    String? @map("media_type")
  mediaCaption String? @map("media_caption")
  mimetype     String?
  fileName     String? @map("file_name")

  quotedMessageId String?   @map("quoted_message_id")
  quotedMessage   Message?  @relation("QuotedMessages", fields: [quotedMessageId], references: [id], onDelete: SetNull)
  quotes          Message[] @relation("QuotedMessages")
  conversationId  String
  senderId        String?
  senderName      String?

  conversation Conversation  @relation("Messages", fields: [conversationId], references: [id], onDelete: Cascade)
  LastMessage  Conversation?

  @@index([conversationId, createdAt])
  @@index([status])
  @@index([fromMe])
  @@map("messages")
}

enum WhatsAppInstanceStatus {
  CONNECTED
  DISCONNECTED
}

model WhatsAppInstance {
  id             String                 @id @default(cuid())
  instanceName   String                 @map("instance_name")
  instanceId     String                 @unique @map("instance_id")
  apiKey         String                 @unique @map("api_key") // Token
  baseUrl        String                 @map("base_url") // URL
  status         WhatsAppInstanceStatus @default(DISCONNECTED)
  qrCode         String?                @map("qr_code") // Base64 do QR Code
  phoneNumber    String?                @map("phone_number") // Número conectado
  profileName    String?                @map("profile_name")
  profilePicUrl  String?                @map("profile_pic_url")
  organizationId String                 @map("organization_id")
  trackingId     String                 @unique @map("tracking_id")
  webhookUrl     String?                @map("webhook_url")
  isActive       Boolean                @default(true) @map("is_active")
  lastSyncAt     DateTime?              @map("last_sync_at")
  createdAt      DateTime               @default(now()) @map("created_at")
  updatedAt      DateTime               @updatedAt @map("updated_at")
  isBusiness     Boolean                @default(false) @map("is_business")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tracking     Tracking     @relation(fields: [trackingId], references: [id])

  @@index([organizationId])
  @@index([status])
  @@map("whatsapp_instances")
}

// ─────────────────────────────────────────────
// REMINDERS
// ─────────────────────────────────────────────

enum ReminderRecurrenceType {
  ONCE
  WEEKLY
  BIWEEKLY
  MONTHLY
}

model Reminder {
  id              String @id @default(cuid())
  createdByUserId String @map("created_by_user_id")

  message        String
  recurrenceType ReminderRecurrenceType @map("recurrence_type")
  dayOfMonth     Int?                   @map("day_of_month")
  remindTime     String                 @map("remind_time")
  notifyPhone    String?                @map("notify_phone")

  nextRemindAt DateTime? @map("next_remind_at")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  leadId         String? @map("lead_id")
  conversationId String? @map("conversation_id")
  trackingId     String? @map("tracking_id")

  lead         Lead?                @relation(fields: [leadId], references: [id], onDelete: SetNull)
  conversation Conversation?        @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  tracking     Tracking?            @relation(fields: [trackingId], references: [id], onDelete: SetNull)
  createdBy    User                 @relation("ReminderCreatedBy", fields: [createdByUserId], references: [id])
  occurrences  ReminderOccurrence[]

  @@index([nextRemindAt, isActive])
  @@index([conversationId])
  @@index([leadId])
  @@index([trackingId])
  @@map("reminders")
}

model ReminderOccurrence {
  id          String    @id @default(cuid())
  reminderId  String    @map("reminder_id")
  scheduledAt DateTime  @map("scheduled_at")
  sent        Boolean   @default(false)
  sentAt      DateTime? @map("sent_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  reminder Reminder @relation(fields: [reminderId], references: [id], onDelete: Cascade)

  @@index([reminderId])
  @@index([scheduledAt, sent])
  @@map("reminder_occurrences")
}

model InsightShares {
  id             String       @id @default(cuid())
  name           String
  token          String       @unique @default(cuid())
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  filters        Json         @default("{}")
  settings       Json         @default("{}")
  userId         String       @map("user_id")
  createdBy      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now()) @map("created_at")

  @@map("insight_shares")
}

// ─────────────────────────────────────────────
// AGENDA
// ─────────────────────────────────────────────

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

model Agenda {
  id             String   @id @default(cuid())
  name           String
  description    String?
  slug           String
  isActive       Boolean  @default(true) @map("is_active")
  slotDuration   Int      @default(30) @map("slot_duration")
  trackingId     String   @map("tracking_id")
  organizationId String   @map("organization_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  tracking     Tracking     @relation(fields: [trackingId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  responsibles       AgendaResponsible[]
  availabilities     AgendaAvailability[]
  appointments       Appointment[]
  publicChatSessions PublicChatSession[]
  dateOverrides      AgendaDateOverride[]
  dateAvailabilities AgendaDateAvailability[]

  @@unique([slug, organizationId])
  @@index([trackingId])
  @@index([organizationId])
  @@index([isActive])
  @@map("agendas")
}

// Responsáveis pela agenda (um ou mais usuários)
model AgendaResponsible {
  id        String   @id @default(cuid())
  agendaId  String   @map("agenda_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  agenda Agenda @relation(fields: [agendaId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([agendaId, userId])
  @@index([agendaId])
  @@index([userId])
  @@map("agenda_responsibles")
}

// Disponibilidade por dia da semana (ex: Segunda, 8h–12h)
model AgendaAvailability {
  id        String    @id @default(cuid())
  agendaId  String    @map("agenda_id")
  dayOfWeek DayOfWeek @map("day_of_week")
  isActive  Boolean   @default(true) @map("is_active")

  agenda    Agenda                 @relation(fields: [agendaId], references: [id], onDelete: Cascade)
  timeSlots AvailabilityTimeSlot[]

  @@unique([agendaId, dayOfWeek])
  @@index([agendaId])
  @@map("agenda_availabilities")
}

// Intervalos de horário dentro de um dia (ex: 8h–12h, 14h–18h)
model AvailabilityTimeSlot {
  id             String @id @default(cuid())
  availabilityId String @map("availability_id")
  startTime      String @map("start_time") // "08:00"
  endTime        String @map("end_time") // "12:00"
  order          Int    @default(0)

  availability AgendaAvailability @relation(fields: [availabilityId], references: [id], onDelete: Cascade)

  @@index([availabilityId])
  @@map("availability_time_slots")
}

// Agendamentos realizados
enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  NO_SHOW
  DONE
}

model Appointment {
  id          String            @id @default(cuid())
  title       String?
  notes       String?
  startsAt    DateTime          @map("starts_at")
  endsAt      DateTime          @map("ends_at")
  status      AppointmentStatus @default(PENDING)
  cancelledBy String?           @map("cancelled_by") // "CLIENT" | "SYSTEM"
  agendaId    String            @map("agenda_id")
  leadId      String?           @map("lead_id")
  userId      String?           @map("user_id")
  trackingId  String?           @map("tracking_id")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  orgProjectId String? @map("org_project_id")

  agenda     Agenda      @relation(fields: [agendaId], references: [id], onDelete: Cascade)
  lead       Lead?       @relation(fields: [leadId], references: [id], onDelete: SetNull)
  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  tracking   Tracking?   @relation(fields: [trackingId], references: [id], onDelete: SetNull)
  orgProject OrgProject? @relation(fields: [orgProjectId], references: [id], onDelete: SetNull)

  @@index([agendaId])
  @@index([leadId])
  @@index([userId])
  @@index([startsAt])
  @@index([status])
  @@map("appointments")
}

// ─────────────────────────────────────────────
// DISPONIBILIDADE POR DATA ESPECÍFICA
// ─────────────────────────────────────────────

// Disponibilidade para uma data específica (sobrepõe o semanal)
model AgendaDateAvailability {
  id        String   @id @default(cuid())
  agendaId  String   @map("agenda_id")
  date      String // YYYY-MM-DD
  createdAt DateTime @default(now()) @map("created_at")

  agenda    Agenda                       @relation(fields: [agendaId], references: [id], onDelete: Cascade)
  timeSlots AgendaDateAvailabilitySlot[]

  @@unique([agendaId, date])
  @@index([agendaId])
  @@map("agenda_date_availabilities")
}

// Intervalos de horário dentro de uma disponibilidade por data específica
model AgendaDateAvailabilitySlot {
  id                 String @id @default(cuid())
  dateAvailabilityId String @map("date_availability_id")
  startTime          String @map("start_time") // "08:00"
  endTime            String @map("end_time") // "12:00"
  order              Int    @default(0)

  dateAvailability AgendaDateAvailability @relation(fields: [dateAvailabilityId], references: [id], onDelete: Cascade)

  @@index([dateAvailabilityId])
  @@map("agenda_date_availability_slots")
}

// ─────────────────────────────────────────────
// CHAT PÚBLICO DE AGENDAMENTO
// ─────────────────────────────────────────────

// Sessão de chat público — criada quando o cliente abre o chat da agenda.
// Não requer autenticação. Expira em 24h.
model PublicChatSession {
  id            String   @id @default(cuid())
  agendaId      String   @map("agenda_id")
  orgSlug       String   @map("org_slug")
  agendaSlug    String   @map("agenda_slug")
  appointmentId String?  @map("appointment_id")
  createdAt     DateTime @default(now()) @map("created_at")
  expiresAt     DateTime @map("expires_at")

  // Auditoria de segurança
  ipAddress String? @map("ip_address")
  userAgent String? @map("user_agent")

  agenda Agenda @relation(fields: [agendaId], references: [id], onDelete: Cascade)

  @@index([agendaId])
  @@index([expiresAt])
  @@map("public_chat_sessions")
}

// ─────────────────────────────────────────────
// EXCEÇÕES DE DATA (bloqueios / disponibilidades pontuais)
// ─────────────────────────────────────────────

// Bloqueia ou desbloqueia uma data específica, sobrepondo a disponibilidade semanal.
model AgendaDateOverride {
  id        String   @id @default(cuid())
  agendaId  String   @map("agenda_id")
  date      String // YYYY-MM-DD
  isBlocked Boolean  @default(true) @map("is_blocked")
  createdAt DateTime @default(now()) @map("created_at")

  agenda Agenda @relation(fields: [agendaId], references: [id], onDelete: Cascade)

  @@unique([agendaId, date])
  @@index([agendaId])
  @@map("agenda_date_overrides")
}

