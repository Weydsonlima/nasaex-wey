  name        String
  workspaceId String   @map("workspace_id")
  isActive    Boolean  @default(true) @map("is_active")
  trigger     String
  triggerData Json     @default("{}") @map("trigger_data")
  conditions  Json     @default("[]") @map("conditions")
  steps       Json     @default("[]") @map("steps")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("workspace_automations")
}

// ─── Action Mirror ────────────────────────────────────────────────────────────

model ActionMirror {
  id             String   @id @default(cuid())
  sourceActionId String   @map("source_action_id")
  mirrorActionId String   @unique @map("mirror_action_id")
  createdAt      DateTime @default(now()) @map("created_at")

  sourceAction Action @relation("SourceMirror", fields: [sourceActionId], references: [id], onDelete: Cascade)
  mirrorAction Action @relation("MirrorOf", fields: [mirrorActionId], references: [id], onDelete: Cascade)

  @@unique([sourceActionId, mirrorActionId])
  @@map("action_mirrors")
}

// ─── Cross-Company Card Sharing ───────────────────────────────────────────────

model ActionShare {
  id                String    @id @default(cuid())
  sourceActionId    String    @map("source_action_id")
  sourceOrgId       String    @map("source_org_id")
  targetOrgId       String    @map("target_org_id")
  targetWorkspaceId String?   @map("target_workspace_id")
  requestedBy       String    @map("requested_by")
  message           String?
  status            String    @default("PENDING") // PENDING | APPROVED | REJECTED
  approvedBy        String?   @map("approved_by")
  rejectedBy        String?   @map("rejected_by")
  approvedAt        DateTime? @map("approved_at")
  rejectedAt        DateTime? @map("rejected_at")
  copiedActionId    String?   @map("copied_action_id")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  sourceAction Action       @relation("SharedAction", fields: [sourceActionId], references: [id], onDelete: Cascade)
  sourceOrg    Organization @relation("SentShares", fields: [sourceOrgId], references: [id], onDelete: Cascade)
  targetOrg    Organization @relation("ReceivedShares", fields: [targetOrgId], references: [id], onDelete: Cascade)
  requester    User         @relation("ShareRequester", fields: [requestedBy], references: [id])

  @@index([sourceOrgId])
  @@index([targetOrgId])
  @@index([status])
  @@map("action_shares")
}

// ─── Sidebar Preferences ─────────────────────────────────────────────────────

model UserSidebarPreference {
  id      String  @id @default(cuid())
  userId  String  @map("user_id")
  itemKey String  @map("item_key") // "app:nasachat" | "workspace:{id}"
  visible Boolean @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, itemKey])
  @@index([userId])
  @@map("user_sidebar_preference")
}

// ─── User Notifications ───────────────────────────────────────────────────────

model UserNotification {
  id             String    @id @default(cuid())
  userId         String    @map("user_id")
  organizationId String?   @map("organization_id")
  type           String // NEW_LEAD | AI_TOKEN_ALERT | STARS_ALERT | CARD_EDIT | APPOINTMENT_REMINDER | INSIGHTS_MOVEMENT | PLAN_EXPIRY | ADMIN_MESSAGE | CUSTOM
  title          String
  body           String
  appKey         String?   @map("app_key")
  actionUrl      String?   @map("action_url")
  metadata       Json?
