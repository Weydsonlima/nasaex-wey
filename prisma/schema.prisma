enum JobCategory {
  EXECUTIVE
  TECH
  DESIGN
  PRODUCT
  MARKETING
  SALES
  OPERATIONS
  FINANCE
  HR
  LEGAL
  OTHER
}

model JobTitleCatalog {
  id        String      @id @default(cuid())
  title     String      @unique
  slug      String      @unique
  category  JobCategory
  level     Int         @default(0) // 0=C-level, 1=diretor, 2=gerente, 3=sênior, 4=pleno, 5=jr
  createdAt DateTime    @default(now()) @map("created_at")

  orgRoles OrgRole[]

  @@index([category, level])
  @@map("job_title_catalog")
}

model OrgRole {
  id          String  @id @default(cuid())
  orgId       String  @map("org_id")
  userId      String? @map("user_id") // null = vaga aberta
  jobTitleId  String  @map("job_title_id")
  customLabel String? @map("custom_label") // complemento opcional
  parentId    String? @map("parent_id")
  department  String?
  order       Int     @default(0)

  // Opt-in explícito do usuário
  publicConsent Boolean   @default(false) @map("public_consent")
  consentedAt   DateTime? @map("consented_at")
  showPhoto     Boolean   @default(true) @map("show_photo")
  showName      Boolean   @default(true) @map("show_name")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org      Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user     User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  jobTitle JobTitleCatalog @relation(fields: [jobTitleId], references: [id])
  parent   OrgRole?        @relation("OrgRoleHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children OrgRole[]       @relation("OrgRoleHierarchy")

  @@index([orgId])
  @@index([parentId])
  @@index([orgId, publicConsent])
  @@map("org_roles")
}

model UserProfileCard {
  id       String  @id @default(cuid())
  userId   String  @unique @map("user_id")
  headline String?
  bio      String?

  cvUrl        String? @map("cv_url")
  linkedinUrl  String? @map("linkedin_url")
  githubUrl    String? @map("github_url")
  portfolioUrl String? @map("portfolio_url")
  email        String?

  // Master switch — default FALSE (opt-in explícito)
  isPublic Boolean @default(false) @map("is_public")

  // Toggles granulares
  showHeadline  Boolean @default(true) @map("show_headline")
  showBio       Boolean @default(true) @map("show_bio")
  showCv        Boolean @default(false) @map("show_cv")
  showLinkedin  Boolean @default(true) @map("show_linkedin")
  showGithub    Boolean @default(true) @map("show_github")
  showPortfolio Boolean @default(true) @map("show_portfolio")
  showEmail     Boolean @default(false) @map("show_email")
  showSkills    Boolean @default(true) @map("show_skills")
  showTools     Boolean @default(true) @map("show_tools")

  updatedAt DateTime @updatedAt @map("updated_at")

  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills UserSkill[]
  tools  UserTool[]

  @@map("user_profile_cards")
}

model Skill {
  id    String      @id @default(cuid())
  name  String      @unique
  slug  String      @unique
  users UserSkill[]

  @@map("skills")
}

model UserSkill {
  id        String   @id @default(cuid())
  profileId String   @map("profile_id")
  skillId   String   @map("skill_id")
  level     Int      @default(3) // 1-5
  createdAt DateTime @default(now()) @map("created_at")

  profile UserProfileCard @relation(fields: [profileId], references: [id], onDelete: Cascade)
  skill   Skill           @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([profileId, skillId])
  @@map("user_skills")
}

model ToolCatalog {
  id       String     @id @default(cuid())
  name     String     @unique
  slug     String     @unique
  iconUrl  String?    @map("icon_url")
  category String?
  users    UserTool[]

  @@map("tool_catalog")
}

model UserTool {
  id          String   @id @default(cuid())
  profileId   String   @map("profile_id")
  toolId      String   @map("tool_id")
  proficiency Int      @default(3) // 1-5
  createdAt   DateTime @default(now()) @map("created_at")

  profile UserProfileCard @relation(fields: [profileId], references: [id], onDelete: Cascade)
  tool    ToolCatalog     @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@unique([profileId, toolId])
  @@map("user_tools")
}

model OrgFollow {
  id        String   @id @default(cuid())
  orgId     String   @map("org_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@index([orgId])
  @@index([userId])
  @@map("org_follows")
}

enum ReviewStatus {
  APPROVED
  PENDING
  HIDDEN
}

model CompanyReview {
  id          String       @id @default(cuid())
  orgId       String       @map("org_id")
  authorId    String?      @map("author_id") // null = anônimo
  authorName  String?      @map("author_name")
  rating      Int // 1-5
  title       String?
  comment     String?
  verified    Boolean      @default(false) // true se authorId in Member
  status      ReviewStatus @default(PENDING) // moderação obrigatória
  ipHash      String?      @map("ip_hash")
  fingerprint String?
  createdAt   DateTime     @default(now()) @map("created_at")

  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  author User?        @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([orgId, status])
  @@index([createdAt])
  @@map("company_reviews")
}

model CompanyPost {
  id          String    @id @default(cuid())
  orgId       String    @map("org_id")
  authorId    String    @map("author_id")
  title       String
  slug        String    @unique
  excerpt     String?
  content     Json // TipTap JSON
  coverUrl    String?   @map("cover_url")
  isPublished Boolean   @default(false) @map("is_published")
  publishedAt DateTime? @map("published_at")
  viewCount   Int       @default(0) @map("view_count")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  org      Organization         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  author   User                 @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments CompanyPostComment[]

  @@index([orgId, isPublished, publishedAt])
  @@map("company_posts")
}

model CompanyPostComment {
  id         String       @id @default(cuid())
  postId     String       @map("post_id")
  authorId   String?      @map("author_id")
  authorName String?      @map("author_name")
  content    String
  parentId   String?      @map("parent_id")
  status     ReviewStatus @default(PENDING) // moderação obrigatória
  createdAt  DateTime     @default(now()) @map("created_at")

  post    CompanyPost          @relation(fields: [postId], references: [id], onDelete: Cascade)
  author  User?                @relation(fields: [authorId], references: [id], onDelete: SetNull)
  parent  CompanyPostComment?  @relation("CommentTree", fields: [parentId], references: [id], onDelete: SetNull)
  replies CompanyPostComment[] @relation("CommentTree")

  @@index([postId, createdAt])
  @@index([status])
  @@map("company_post_comments")
}

model SpacehomeAuditLog {
  id        String   @id @default(cuid())
  orgId     String   @map("org_id")
  actorId   String?  @map("actor_id")
  action    String // "review_submitted", "review_moderated", "role_consented", "space_toggled_public"
